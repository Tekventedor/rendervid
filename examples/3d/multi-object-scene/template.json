                  "color": "#ffffff",
                  "intensity": 1.2,
                  "position": [8, 10, 6],
                  "castShadow": true,
                  "shadowMapSize": 2048
                },
                {
                  "type": "point",
                  "color": "#ff6b6b",
                  "intensity": 1.5,
                  "position": [-4, 4, 4],
                  "distance": 20
                },
                {
                  "type": "point",
                  "color": "#4c00ff",
