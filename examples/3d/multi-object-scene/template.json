                    "heightSegments": 32
                  },
                  "material": {
                    "type": "standard",
                    "color": "#ffffff",
                    "metalness": 0.8,
                    "roughness": 0.2,
                    "emissive": "#667eea",
                    "emissiveIntensity": 0.3
                  },
                  "position": [0, 0, 0],
                  "castShadow": true,
                  "receiveShadow": true,
                  "autoRotate": [0, 0.008, 0]
