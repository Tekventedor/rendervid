                  "rotation": [-1.5708, 0, 0],
                  "receiveShadow": true
                }
              ],
              "shadows": {
                "enabled": true,
                "type": "pcfsoft"
              },
              "fog": {
                "color": "#2d2d3a",
                "near": 8,
                "far": 25
              },
              "toneMapping": {
                "type": "aces",
                "exposure": 1
              },
              "antialias": true
