              "text": "7 Different Geometries • Complex Animations • Dynamic Lighting",
              "fontSize": 24,
              "color": "#ffffff",
              "textAlign": "center",
              "opacity": 0.9,
              "textShadow": "0 2px 8px rgba(0,0,0,0.4)"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 35,
                "duration": 20
              }
            ]
          },
          {
            "id": "feature-box",
            "type": "shape",
            "position": { "x": 100, "y": 880 },
            "size": { "width": 500, "height": 120 },
            "props": {
              "shape": "rectangle",
              "fill": "rgba(0, 0, 0, 0.6)",
              "cornerRadius": 12
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInLeft",
                "delay": 60,
                "duration": 25
              }
            ]
          },
          {
            "id": "features",
            "type": "text",
            "position": { "x": 130, "y": 910 },
            "size": { "width": 440, "height": 100 },
            "props": {
              "text": "• Sphere, Cube, Torus, Cone, Cylinder\n• PBR Materials & Shadows\n• Atmospheric Fog",
              "fontSize": 20,
              "color": "#ffffff",
              "lineHeight": 1.6
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 70,
                "duration": 20
              }
            ]
          }
        ]
      }
    ]
  }
}
