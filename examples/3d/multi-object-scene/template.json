{
  "name": "Multi-Object Scene",
  "description": "Complex 3D scene with multiple objects, different geometries, materials, and coordinated animations.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 10
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 300,
        "layers": [
          {
            "id": "background",
            "type": "shape",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 1920, "height": 1080 },
            "props": {
              "shape": "rectangle",
              "fill": "linear-gradient(135deg, #667eea 0%, #764ba2 100%)"
            }
          },
          {
            "id": "three-scene",
            "type": "three",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 1920, "height": 1080 },
