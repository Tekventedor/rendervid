{
  "name": "Product Showcase",
  "description": "Professional product visualization with studio lighting, shadows, and camera orbit animation.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 3840,
    "height": 2160,
    "fps": 30,
    "duration": 8
  },
  "inputs": [
    {
      "key": "productName",
      "type": "string",
      "label": "Product Name",
      "required": false,
      "default": "Premium Product"
    },
    {
      "key": "productColor",
      "type": "color",
      "label": "Product Color",
      "required": false,
      "default": "#4c00ff"
    }
  ],
  "defaults": {
    "productName": "Premium Product",
    "productColor": "#4c00ff"
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 240,
        "layers": [
          {
            "id": "background",
            "type": "shape",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 3840, "height": 2160 },
            "props": {
              "shape": "rectangle",
              "fill": "linear-gradient(180deg, #f5f7fa 0%, #c3cfe2 100%)"
            }
          },
          {
            "id": "three-scene",
            "type": "three",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 3840, "height": 2160 },
            "props": {
              "camera": {
                "type": "perspective",
                "fov": 50,
                "position": [0, 2, 8],
                "lookAt": [0, 0, 0]
              },
              "lights": [
                {
                  "type": "ambient",
                  "color": "#ffffff",
                  "intensity": 0.6
                },
                {
                  "type": "directional",
                  "color": "#ffffff",
                  "intensity": 1.5,
                  "position": [10, 10, 5],
                  "castShadow": true,
                  "shadowMapSize": 2048
                },
                {
                  "type": "directional",
                  "color": "#ffffff",
                  "intensity": 0.5,
                  "position": [-5, 5, -5]
                },
                {
                  "type": "hemisphere",
                  "color": "#ffffff",
                  "groundColor": "#888888",
                  "intensity": 0.4
                },
                {
                  "type": "point",
                  "color": "#4c00ff",
                  "intensity": 0.8,
                  "position": [3, 2, 3],
                  "distance": 20,
                  "decay": 2
                }
              ],
              "meshes": [
                {
                  "id": "product",
                  "geometry": {
                    "type": "sphere",
                    "radius": 1.5,
                    "widthSegments": 64,
                    "heightSegments": 32
                  },
                  "material": {
                    "type": "physical",
                    "color": "{{productColor}}",
                    "metalness": 0.5,
                    "roughness": 0.2,
                    "clearcoat": 0.8,
                    "clearcoatRoughness": 0.1,
                    "envMapIntensity": 1
                  },
                  "position": [0, 0, 0],
                  "castShadow": true,
                  "receiveShadow": true,
                  "autoRotate": [0, 0.015, 0]
                },
                {
                  "id": "floor",
                  "geometry": {
                    "type": "plane",
                    "width": 60,
                    "height": 60
                  },
                  "material": {
                    "type": "standard",
                    "color": "#ffffff",
                    "roughness": 0.7,
                    "metalness": 0.1
                  },
                  "position": [0, -1.5, 0],
                  "rotation": [-1.5708, 0, 0],
                  "receiveShadow": true
                },
                {
                  "id": "backdrop",
                  "geometry": {
                    "type": "plane",
                    "width": 60,
                    "height": 30
                  },
                  "material": {
                    "type": "standard",
                    "color": "#f0f0f0",
                    "roughness": 1
                  },
                  "position": [0, 8, -10]
                }
              ],
              "shadows": {
                "enabled": true,
                "type": "pcfsoft"
              },
              "toneMapping": {
                "type": "aces",
                "exposure": 1.2
              },
              "antialias": true
            }
          },
          {
            "id": "title",
            "type": "text",
            "position": { "x": 0, "y": 200 },
            "size": { "width": 3840, "height": 200 },
            "props": {
              "text": "{{productName}}",
              "fontSize": 128,
              "fontWeight": "bold",
              "color": "#1a1a2e",
              "textAlign": "center",
              "letterSpacing": 4
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInDown",
                "delay": 15,
                "duration": 230,
                "easing": "easeOutCubic"
              }
            ]
          },
          {
            "id": "subtitle",
            "type": "text",
            "position": { "x": 0, "y": 380 },
            "size": { "width": 3840, "height": 120 },
            "props": {
              "text": "Studio Quality 3D Rendering",
              "fontSize": 56,
              "color": "#666666",
              "textAlign": "center",
              "letterSpacing": 2
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 35,
                "duration": 210
              }
            ]
          },
          {
            "id": "feature-1",
            "type": "text",
            "position": { "x": 200, "y": 1700 },
            "size": { "width": 800, "height": 300 },
            "props": {
              "text": "• Physically-Based Rendering\n• Real-time Shadows\n• HDR Tone Mapping",
              "fontSize": 44,
              "color": "#333333",
              "lineHeight": 1.8
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInLeft",
                "delay": 60,
                "duration": 185
              }
            ]
          },
          {
            "id": "cta",
            "type": "shape",
            "position": { "x": 2840, "y": 1800 },
            "size": { "width": 800, "height": 160 },
            "props": {
              "shape": "rectangle",
              "fill": "#4c00ff",
              "cornerRadius": 80
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 90,
                "duration": 155
              }
            ]
          },
          {
            "id": "cta-text",
            "type": "text",
            "position": { "x": 3240, "y": 1880 },
            "anchor": { "x": 0.5, "y": 0.5 },
            "size": { "width": 760, "height": 160 },
            "props": {
              "text": "Learn More",
              "fontSize": 56,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "center"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 95,
                "duration": 150
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": { "x": 3040, "y": 40 },
            "size": { "width": 760, "height": 120 },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 32,
              "fontWeight": "600",
              "color": "#333333",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.5
            }
          }
        ]
      }
    ]
  }
}
