{
  "name": "Product Showcase",
  "description": "Professional product visualization with studio lighting, shadows, and camera orbit animation.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 8
  },
  "inputs": [
    {
      "key": "productName",
      "type": "string",
      "label": "Product Name",
      "required": false,
      "default": "Premium Product"
    },
    {
      "key": "productColor",
      "type": "color",
      "label": "Product Color",
      "required": false,
      "default": "#4c00ff"
    }
  ],
  "defaults": {
    "productName": "Premium Product",
    "productColor": "#4c00ff"
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 240,
        "layers": [
          {
            "id": "background",
            "type": "shape",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 1920, "height": 1080 },
            "props": {
              "shape": "rectangle",
              "fill": "linear-gradient(180deg, #f5f7fa 0%, #c3cfe2 100%)"
            }
          },
          {
            "id": "three-scene",
            "type": "three",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 1920, "height": 1080 },
            "props": {
              "camera": {
                "type": "perspective",
                "fov": 50,
                "position": [0, 2, 8],
                "lookAt": [0, 0, 0]
              },
              "lights": [
                {
                  "type": "directional",
                  "color": "#ffffff",
                  "intensity": 1.5,
                  "position": [10, 10, 5],
                  "castShadow": true,
                  "shadowMapSize": 2048
                },
                {
                  "type": "directional",
                  "color": "#ffffff",
                  "intensity": 0.5,
                  "position": [-5, 5, -5]
                },
                {
                  "type": "hemisphere",
                  "color": "#ffffff",
                  "groundColor": "#888888",
                  "intensity": 0.6
                },
                {
                  "type": "point",
                  "color": "#4c00ff",
                  "intensity": 0.8,
                  "position": [3, 2, 3],
                  "distance": 20,
                  "decay": 2
                }
              ],
              "meshes": [
                {
                  "id": "product",
                  "geometry": {
                    "type": "sphere",
                    "radius": 1.5,
                    "widthSegments": 64,
                    "heightSegments": 32
                  },
                  "material": {
                    "type": "physical",
                    "color": "{{productColor}}",
                    "metalness": 0.9,
                    "roughness": 0.1,
                    "clearcoat": 1,
                    "clearcoatRoughness": 0,
                    "envMapIntensity": 1
                  },
                  "position": [0, 0, 0],
                  "castShadow": true,
                  "receiveShadow": true,
                  "autoRotate": [0, 0.015, 0]
                },
                {
                  "id": "floor",
                  "geometry": {
                    "type": "plane",
                    "width": 20,
                    "height": 20
                  },
                  "material": {
                    "type": "standard",
                    "color": "#ffffff",
                    "roughness": 0.7,
                    "metalness": 0.1
                  },
                  "position": [0, -1.5, 0],
                  "rotation": [-1.5708, 0, 0],
                  "receiveShadow": true
                },
                {
                  "id": "backdrop",
                  "geometry": {
                    "type": "plane",
                    "width": 20,
                    "height": 20
                  },
                  "material": {
                    "type": "standard",
                    "color": "#f0f0f0",
                    "roughness": 1
                  },
                  "position": [0, 5, -10]
                }
              ],
              "shadows": {
                "enabled": true,
                "type": "pcfsoft"
              },
              "toneMapping": {
                "type": "aces",
                "exposure": 1.2
              },
              "antialias": true
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "duration": 30
              }
            ]
          },
          {
            "id": "title",
            "type": "text",
            "position": { "x": 960, "y": 100 },
            "anchor": { "x": 0.5, "y": 0 },
            "size": { "width": 1200, "height": 100 },
            "props": {
              "text": "{{productName}}",
              "fontSize": 64,
              "fontWeight": "bold",
              "color": "#1a1a2e",
              "textAlign": "center",
              "letterSpacing": 2
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInDown",
                "delay": 15,
                "duration": 25,
                "easing": "easeOutCubic"
              }
            ]
          },
          {
            "id": "subtitle",
            "type": "text",
            "position": { "x": 960, "y": 190 },
            "anchor": { "x": 0.5, "y": 0 },
            "size": { "width": 1000, "height": 60 },
            "props": {
              "text": "Studio Quality 3D Rendering",
              "fontSize": 28,
              "color": "#666666",
              "textAlign": "center",
              "letterSpacing": 1
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 35,
                "duration": 20
              }
            ]
          },
          {
            "id": "feature-1",
            "type": "text",
            "position": { "x": 100, "y": 850 },
            "size": { "width": 400, "height": 150 },
            "props": {
              "text": "• Physically-Based Rendering\n• Real-time Shadows\n• HDR Tone Mapping",
              "fontSize": 22,
              "color": "#333333",
              "lineHeight": 1.8
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInLeft",
                "delay": 60,
                "duration": 25
              }
            ]
          },
          {
            "id": "cta",
            "type": "shape",
            "position": { "x": 1420, "y": 900 },
            "size": { "width": 400, "height": 80 },
            "props": {
              "shape": "rectangle",
              "fill": "#4c00ff",
              "cornerRadius": 40
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 90,
                "duration": 20,
                "easing": "easeOutBack"
              }
            ]
          },
          {
            "id": "cta-text",
            "type": "text",
            "position": { "x": 1620, "y": 940 },
            "anchor": { "x": 0.5, "y": 0.5 },
            "size": { "width": 380, "height": 80 },
            "props": {
              "text": "Learn More",
              "fontSize": 28,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "center"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 95,
                "duration": 15
              }
            ]
          }
        ]
      }
    ]
  }
}
