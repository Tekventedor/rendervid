{
  "name": "3D Rotating Cube",
  "description": "A 3D rotating cube with customizable colors and rotation speed, showcasing Three.js layer capabilities.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 3840,
    "height": 2160,
    "fps": 30,
    "duration": 5
  },
  "inputs": [
    {
      "key": "title",
      "type": "string",
      "label": "Title Text",
      "required": false,
      "default": "3D CUBE"
    },
    {
      "key": "cubeColor",
      "type": "color",
      "label": "Cube Color",
      "required": false,
      "default": "#4c00ff"
    },
    {
      "key": "backgroundColor",
      "type": "color",
      "label": "Background Color",
      "required": false,
      "default": "#1a1a2e"
    }
  ],
  "defaults": {
    "title": "3D CUBE",
    "cubeColor": "#4c00ff",
    "backgroundColor": "#1a1a2e"
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 150,
        "layers": [
          {
            "id": "background",
            "type": "shape",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 3840, "height": 2160 },
            "props": {
              "shape": "rectangle",
              "fill": "{{backgroundColor}}"
            }
          },
          {
            "id": "three-scene",
            "type": "three",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 3840, "height": 2160 },
            "props": {
              "camera": {
                "type": "perspective",
                "fov": 60,
                "position": [0, 1, 5],
                "lookAt": [0, 0, 0]
              },
              "lights": [
                {
                  "type": "ambient",
                  "color": "#ffffff",
                  "intensity": 0.5
                },
                {
                  "type": "directional",
                  "color": "#ffffff",
                  "intensity": 1.2,
                  "position": [5, 5, 5]
                },
                {
                  "type": "directional",
                  "color": "#8899ff",
                  "intensity": 0.4,
                  "position": [-5, -2, -3]
                }
              ],
              "meshes": [
                {
                  "id": "cube",
                  "geometry": {
                    "type": "box",
                    "width": 2.2,
                    "height": 2.2,
                    "depth": 2.2
                  },
                  "material": {
                    "type": "standard",
                    "color": "{{cubeColor}}",
                    "metalness": 0.4,
                    "roughness": 0.3,
                    "emissive": "{{cubeColor}}",
                    "emissiveIntensity": 0.05
                  },
                  "castShadow": true,
                  "receiveShadow": true,
                  "autoRotate": [0.01, 0.02, 0.006]
                }
              ],
              "toneMapping": {
                "type": "aces",
                "exposure": 1.1
              },
              "antialias": true
            }
          },
          {
            "id": "title",
            "type": "text",
            "position": { "x": 920, "y": 1560 },
            "size": { "width": 2000, "height": 240 },
            "props": {
              "text": "{{title}}",
              "fontSize": 144,
              "fontWeight": "bold",
              "color": "#ffffff",
              "textAlign": "center",
              "letterSpacing": 16
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInUp",
                "delay": 25,
                "duration": 20
              }
            ]
          },
          {
            "id": "subtitle",
            "type": "text",
            "position": { "x": 1120, "y": 1760 },
            "size": { "width": 1600, "height": 120 },
            "props": {
              "text": "Powered by Three.js • React Three Fiber",
              "fontSize": 56,
              "color": "#a0a0a0",
              "textAlign": "center"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 35,
                "duration": 15
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": { "x": 3040, "y": 40 },
            "size": { "width": 760, "height": 120 },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 32,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7,
              "textShadow": "0 2px 4px rgba(0,0,0,0.5)"
            }
          }
        ]
      }
    ]
  }
}
