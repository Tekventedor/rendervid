{
  "name": "3D Sphere Animation",
  "description": "A wireframe sphere with smooth rotation and futuristic styling, perfect for tech and sci-fi content.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 3840,
    "height": 2160,
    "fps": 30,
    "duration": 6
  },
  "inputs": [
    {
      "key": "title",
      "type": "string",
      "label": "Title Text",
      "required": false,
      "default": "FUTURISTIC TECH"
    },
    {
      "key": "subtitle",
      "type": "string",
      "label": "Subtitle Text",
      "required": false,
      "default": "Next Generation 3D"
    },
    {
      "key": "sphereColor",
      "type": "color",
      "label": "Sphere Color",
      "required": false,
      "default": "#00ffff"
    },
    {
      "key": "accentColor",
      "type": "color",
      "label": "Accent Color",
      "required": false,
      "default": "#ff00ff"
    }
  ],
  "defaults": {
    "title": "FUTURISTIC TECH",
    "subtitle": "Next Generation 3D",
    "sphereColor": "#00ffff",
    "accentColor": "#ff00ff"
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 180,
        "layers": [
          {
            "id": "background",
            "type": "shape",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 3840, "height": 2160 },
            "props": {
              "shape": "rectangle",
              "fill": "#0a0a0f"
            }
          },
          {
            "id": "bg-gradient-1",
            "type": "shape",
            "position": { "x": -200, "y": -200 },
            "size": { "width": 1600, "height": 1600 },
            "opacity": 0.1,
            "props": {
              "shape": "circle",
              "fill": "{{accentColor}}"
            }
          },
          {
            "id": "bg-gradient-2",
            "type": "shape",
            "position": { "x": 2440, "y": 760 },
            "size": { "width": 1200, "height": 1200 },
            "opacity": 0.08,
            "props": {
              "shape": "circle",
              "fill": "{{sphereColor}}"
            }
          },
          {
            "id": "three-scene",
            "type": "three",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 3840, "height": 2160 },
            "props": {
              "camera": {
                "type": "perspective",
                "fov": 50,
                "position": [0, 0, 6],
                "lookAt": [0, 0, 0]
              },
              "lights": [
                {
                  "type": "ambient",
                  "color": "#ffffff",
                  "intensity": 2.0
                }
              ],
              "meshes": [
                {
                  "id": "sphere",
                  "geometry": {
                    "type": "sphere",
                    "radius": 2.5,
                    "widthSegments": 24,
                    "heightSegments": 16
                  },
                  "material": {
                    "type": "standard",
                    "color": "{{sphereColor}}",
                    "wireframe": true,
                    "metalness": 0.0,
                    "roughness": 1.0
                  },
                  "autoRotate": [0.003, 0.007, 0]
                },
                {
                  "id": "sphere-inner",
                  "geometry": {
                    "type": "sphere",
                    "radius": 1.8,
                    "widthSegments": 16,
                    "heightSegments": 12
                  },
                  "material": {
                    "type": "standard",
                    "color": "{{accentColor}}",
                    "wireframe": true,
                    "metalness": 0.0,
                    "roughness": 1.0,
                    "transparent": true,
                    "opacity": 0.4
                  },
                  "autoRotate": [-0.005, 0.01, 0.003]
                }
              ],
              "antialias": true
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 10,
                "duration": 30
              }
            ]
          },
          {
            "id": "title",
            "type": "text",
            "position": { "x": 720, "y": 240 },
            "size": { "width": 2400, "height": 200 },
            "props": {
              "text": "{{title}}",
              "fontSize": 168,
              "fontWeight": "900",
              "color": "#ffffff",
              "textAlign": "center",
              "letterSpacing": 24
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInDown",
                "delay": 20,
                "duration": 25,
                "easing": "easeOutQuad"
              }
            ]
          },
          {
            "id": "title-accent",
            "type": "shape",
            "position": { "x": 1720, "y": 410 },
            "size": { "width": 400, "height": 8 },
            "props": {
              "shape": "rectangle",
              "fill": "{{accentColor}}"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 40,
                "duration": 20
              }
            ]
          },
          {
            "id": "subtitle",
            "type": "text",
            "position": { "x": 1120, "y": 1760 },
            "size": { "width": 1600, "height": 160 },
            "props": {
              "text": "{{subtitle}}",
              "fontSize": 72,
              "fontWeight": "300",
              "color": "{{sphereColor}}",
              "textAlign": "center",
              "letterSpacing": 8
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 45,
                "duration": 20
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": { "x": 3040, "y": 40 },
            "size": { "width": 760, "height": 120 },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 32,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7,
              "textShadow": "0 2px 4px rgba(0,0,0,0.5)"
            }
          }
        ]
      }
    ]
  }
}
