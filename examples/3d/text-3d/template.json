{
  "name": "3D Text",
  "description": "Extruded 3D text with dramatic lighting, metallic material, and cinematic presentation.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 3840,
    "height": 2160,
    "fps": 30,
    "duration": 6
  },
  "inputs": [
    {
      "key": "text",
      "type": "string",
      "label": "3D Text",
      "required": false,
      "default": "RENDERVID"
    },
    {
      "key": "textColor",
      "type": "color",
      "label": "Text Color",
      "required": false,
      "default": "#4c00ff"
    }
  ],
  "defaults": {
    "text": "RENDERVID",
    "textColor": "#4c00ff"
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 180,
        "layers": [
          {
            "id": "background",
            "type": "shape",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 3840, "height": 2160 },
            "props": {
              "shape": "rectangle",
              "fill": "#000000"
            }
          },
          {
            "id": "three-scene",
            "type": "three",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 3840, "height": 2160 },
            "props": {
              "camera": {
                "type": "perspective",
                "fov": 75,
                "position": [0, 2, 12],
                "lookAt": [0, 0, 0]
              },
              "lights": [
                {
                  "type": "ambient",
                  "color": "#ffffff",
                  "intensity": 0.8
                },
                {
                  "type": "directional",
                  "color": "#ffffff",
                  "intensity": 2,
                  "position": [10, 10, 10],
                  "castShadow": true,
                  "shadowMapSize": 2048
                },
                {
                  "type": "point",
                  "color": "#ff6b6b",
                  "intensity": 3,
                  "position": [-8, 3, 5],
                  "distance": 30
                },
                {
                  "type": "point",
                  "color": "#4c00ff",
                  "intensity": 3,
                  "position": [8, 3, 5],
                  "distance": 30
                },
                {
                  "type": "spot",
                  "color": "#ffffff",
                  "intensity": 2,
                  "position": [0, 10, 8],
                  "target": [0, 0, 0],
                  "angle": 0.5,
                  "penumbra": 0.3,
                  "castShadow": true
                }
              ],
              "meshes": [
                {
                  "id": "text-3d",
                  "geometry": {
                    "type": "text3d",
                    "text": "{{text}}",
                    "font": "https://threejs.org/examples/fonts/helvetiker_bold.typeface.json",
                    "size": 2,
                    "height": 0.5,
                    "curveSegments": 12,
                    "bevelEnabled": true,
                    "bevelThickness": 0.15,
                    "bevelSize": 0.1,
                    "bevelSegments": 5
                  },
                  "material": {
                    "type": "physical",
                    "color": "{{textColor}}",
                    "metalness": 0.9,
                    "roughness": 0.1,
                    "clearcoat": 1,
                    "clearcoatRoughness": 0.1,
                    "emissive": "{{textColor}}",
                    "emissiveIntensity": 0.2
                  },
                  "position": [-8, 0, 0],
                  "castShadow": true,
                  "receiveShadow": true,
                  "autoRotate": [0, 0.005, 0]
                },
                {
                  "id": "floor",
                  "geometry": {
                    "type": "plane",
                    "width": 80,
                    "height": 80
                  },
                  "material": {
                    "type": "standard",
                    "color": "#111130",
                    "roughness": 0.9,
                    "metalness": 0.1
                  },
                  "position": [0, -2, 0],
                  "rotation": [-1.5708, 0, 0],
                  "receiveShadow": true
                },
                {
                  "id": "backdrop-plane",
                  "geometry": {
                    "type": "plane",
                    "width": 80,
                    "height": 40
                  },
                  "material": {
                    "type": "standard",
                    "color": "#0d0d20",
                    "roughness": 1
                  },
                  "position": [0, 10, -15]
                }
              ],
              "shadows": {
                "enabled": true,
                "type": "pcfsoft"
              },
              "fog": {
                "color": "#000000",
                "near": 25,
                "far": 60
              },
              "toneMapping": {
                "type": "aces",
                "exposure": 1.3
              },
              "antialias": true
            }
          },
          {
            "id": "subtitle",
            "type": "text",
            "position": { "x": 1920, "y": 1900 },
            "anchor": { "x": 0.5, "y": 0.5 },
            "size": { "width": 2800, "height": 160 },
            "props": {
              "text": "Extruded 3D Text with Physical Materials",
              "fontSize": 64,
              "color": "#ffffff",
              "textAlign": "center",
              "opacity": 0.8,
              "textShadow": "0 2px 10px rgba(0,0,0,0.8)"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInUp",
                "delay": 40,
                "duration": 25
              }
            ]
          },
          {
            "id": "particle-1",
            "type": "shape",
            "position": { "x": 600, "y": 600 },
            "size": { "width": 40, "height": 40 },
            "props": {
              "shape": "circle",
              "fill": "#ff6b6b",
              "opacity": 0.6
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 30,
                "duration": 20
              }
            ]
          },
          {
            "id": "particle-2",
            "type": "shape",
            "position": { "x": 3240, "y": 600 },
            "size": { "width": 40, "height": 40 },
            "props": {
              "shape": "circle",
              "fill": "#4c00ff",
              "opacity": 0.6
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 30,
                "duration": 20
              }
            ]
          },
          {
            "id": "particle-3",
            "type": "shape",
            "position": { "x": 300, "y": 1400 },
            "size": { "width": 30, "height": 30 },
            "props": {
              "shape": "circle",
              "fill": "#51cf66",
              "opacity": 0.5
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 45,
                "duration": 20
              }
            ]
          },
          {
            "id": "particle-4",
            "type": "shape",
            "position": { "x": 3540, "y": 1400 },
            "size": { "width": 30, "height": 30 },
            "props": {
              "shape": "circle",
              "fill": "#ffd43b",
              "opacity": 0.5
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 45,
                "duration": 20
              }
            ]
          }
        ]
      }
    ]
  }
}
