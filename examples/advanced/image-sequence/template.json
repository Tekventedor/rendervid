{
  "name": "Image Sequence Demo",
  "description": "A simple template for demonstrating image sequence export.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1280,
    "height": 720,
    "fps": 24,
    "duration": 2
  },
  "inputs": [
    {
      "key": "title",
      "type": "string",
      "label": "Title",
      "description": "The text to display",
      "required": false,
      "default": "Image Sequence Export"
    }
  ],
  "defaults": {
    "title": "Image Sequence Export"
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 48,
        "layers": [
          {
            "id": "background",
            "type": "shape",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 1280, "height": 720 },
            "props": {
              "shape": "rectangle",
              "fill": "#0d1117"
            }
          },
          {
            "id": "title-text",
            "type": "text",
            "position": { "x": 140, "y": 300 },
            "size": { "width": 1000, "height": 120 },
            "props": {
              "text": "{{title}}",
              "fontSize": 64,
              "fontWeight": "bold",
              "color": "#58a6ff",
              "textAlign": "center",
              "fontFamily": "Inter, system-ui, sans-serif"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 0,
                "duration": 24,
                "easing": "easeOutCubic"
              }
            ]
          }
        ]
      }
    ]
  }
}
