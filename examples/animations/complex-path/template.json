      "description": "Ball follows complex path: easeInOutElastic on X axis, easeInOutBack on Y axis — creates organic figure-8-like trajectory",
      "code": "function(props){var f=props.frame,W=props.layerSize.width,H=props.layerSize.height,PI=Math.PI,c5=(2*PI)/4.5;function eie(t){if(t<=0)return 0;if(t>=1)return 1;if(t<0.5)return-(Math.pow(2,20*t-10)*Math.sin((20*t-11.125)*c5))/2;return(Math.pow(2,-20*t+10)*Math.sin((20*t-11.125)*c5))/2+1;}function eib(t){var c1=1.70158,c2=c1*1.525;if(t<0.5)return(Math.pow(2*t,2)*((c2+1)*2*t-c2))/2;return(Math.pow(2*t-2,2)*((c2+1)*(2*t-2)+c2)+2)/2;}var ph=((f%100)/100)*2,tn=ph<1?ph:2-ph,x=250+eie(tn)*1420,y=350+eib(tn)*380,cx=x+50,cy=y+50;return React.createElement('svg',{xmlns:'http://www.w3.org/2000/svg',width:W,height:H,style:{position:'absolute',top:0,left:0}},React.createElement('line',{x1:250,y1:350,x2:1670,y2:730,stroke:'#003300',strokeWidth:1,opacity:0.3}),React.createElement('ellipse',{cx:cx,cy:cy,rx:70,ry:70,fill:'#00ff00',opacity:0.15}),React.createElement('ellipse',{cx:cx,cy:cy,rx:50,ry:50,fill:'#00ff00',style:{filter:'drop-shadow(0 0 25px #00ff00)'}}),React.createElement('text',{x:80,y:900,fill:'#00aa00',fontSize:28,fontFamily:'monospace'},'easeInOutElastic (X) \u00d7 easeInOutBack (Y)'));}"
    }
