{
  "name": "Animation Engine - Multiple Easings",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 5
  },
  "composition": {
    "scenes": [{
      "id": "main",
      "startFrame": 0,
      "endFrame": 150,
      "backgroundColor": "#1a1a2e",
      "layers": [{
        "id": "three-scene",
        "type": "three",
        "position": {"x": 0, "y": 0},
        "size": {"width": 1920, "height": 1080},
        "props": {
          "camera": {
            "type": "perspective",
            "position": [0, 0, 20],
            "lookAt": [0, 0, 0],
            "fov": 50
          },
          "lights": [
            {"type": "ambient", "color": "#ffffff", "intensity": 1}
          ],
          "meshes": [
            {
              "id": "linear",
              "geometry": {"type": "box", "width": 1, "height": 1, "depth": 1},
              "material": {"type": "standard", "color": "#ff6b6b", "metalness": 0.5, "roughness": 0.5},
              "position": [-8, 4, 0],
              "animations": [
                {"property": "position.x", "keyframes": [{"frame": 0, "value": -8}, {"frame": 120, "value": 8}], "easing": "linear"}
              ]
            },
            {
              "id": "easeInOutCubic",
              "geometry": {"type": "box", "width": 1, "height": 1, "depth": 1},
              "material": {"type": "standard", "color": "#4ecdc4", "metalness": 0.5, "roughness": 0.5},
              "position": [-8, 2, 0],
              "animations": [
                {"property": "position.x", "keyframes": [{"frame": 0, "value": -8}, {"frame": 120, "value": 8}], "easing": "easeInOutCubic"}
              ]
            },
            {
              "id": "easeOutBounce",
              "geometry": {"type": "box", "width": 1, "height": 1, "depth": 1},
              "material": {"type": "standard", "color": "#ffe66d", "metalness": 0.5, "roughness": 0.5},
              "position": [-8, 0, 0],
              "animations": [
                {"property": "position.x", "keyframes": [{"frame": 0, "value": -8}, {"frame": 120, "value": 8}], "easing": "easeOutBounce"}
              ]
            },
            {
              "id": "easeInOutElastic",
              "geometry": {"type": "box", "width": 1, "height": 1, "depth": 1},
              "material": {"type": "standard", "color": "#a8e6cf", "metalness": 0.5, "roughness": 0.5},
              "position": [-8, -2, 0],
              "animations": [
                {"property": "position.x", "keyframes": [{"frame": 0, "value": -8}, {"frame": 120, "value": 8}], "easing": "easeInOutElastic"}
              ]
            },
            {
              "id": "easeInOutBack",
              "geometry": {"type": "box", "width": 1, "height": 1, "depth": 1},
              "material": {"type": "standard", "color": "#ff8b94", "metalness": 0.5, "roughness": 0.5},
              "position": [-8, -4, 0],
              "animations": [
                {"property": "position.x", "keyframes": [{"frame": 0, "value": -8}, {"frame": 120, "value": 8}], "easing": "easeInOutBack"}
              ]
            }
          ]
        }
      }]
    }]
  }
}
