{
  "name": "Wave Energy",
  "description": "High-energy wave background with vibrant purple/pink colors and waves from both top and bottom. Perfect for tech, gaming, and energetic content.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 5
  },
  "inputs": [
    {
      "key": "title",
      "type": "string",
      "label": "Main Title (First Line)",
      "required": true,
      "default": "UNLEASH"
    },
    {
      "key": "subtitle",
      "type": "string",
      "label": "Subtitle (Second Line)",
      "required": true,
      "default": "THE POWER"
    },
    {
      "key": "tagline",
      "type": "string",
      "label": "Tagline",
      "required": false,
      "default": "Next Generation Technology"
    },
    {
      "key": "waveColors",
      "type": "array",
      "label": "Wave Colors",
      "required": false,
      "default": ["#8b5cf6", "#d946ef", "#ec4899"],
      "description": "Array of hex color codes for wave layers"
    },
    {
      "key": "waveSpeed",
      "type": "number",
      "label": "Wave Speed",
      "required": false,
      "default": 0.8,
      "min": 0.3,
      "max": 2.0
    },
    {
      "key": "waveCount",
      "type": "number",
      "label": "Wave Count",
      "required": false,
      "default": 3,
      "min": 1,
      "max": 3
    },
    {
      "key": "amplitude",
      "type": "number",
      "label": "Wave Amplitude",
      "required": false,
      "default": 70,
      "min": 40,
      "max": 120
    }
  ],
  "defaults": {
    "title": "UNLEASH",
    "subtitle": "THE POWER",
    "tagline": "Next Generation Technology",
    "waveColors": ["#8b5cf6", "#d946ef", "#ec4899"],
    "waveSpeed": 0.8,
    "waveCount": 3,
    "amplitude": 70
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 150,
        "layers": [
          {
            "id": "background",
            "type": "shape",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 1920, "height": 1080 },
            "props": {
              "shape": "rectangle",
              "fill": "#0f0a1e"
            }
          },
          {
            "id": "wave-background",
            "type": "custom",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 1920, "height": 1080 },
            "customComponent": {
              "name": "wave-background",
              "props": {
                "frame": 0,
                "fps": 30,
                "colors": "{{waveColors}}",
                "speed": "{{waveSpeed}}",
                "waveCount": "{{waveCount}}",
                "amplitude": "{{amplitude}}",
                "direction": "both"
              }
            }
          },
          {
            "id": "title",
            "type": "text",
            "position": { "x": 460, "y": 380 },
            "size": { "width": 1000, "height": 140 },
            "props": {
              "text": "{{title}}",
              "fontSize": 120,
              "fontWeight": "900",
              "color": "#ffffff",
              "textAlign": "center",
              "letterSpacing": 16,
              "textShadow": "0 4px 30px rgba(139, 92, 246, 0.8)"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 20,
                "duration": 30,
                "easing": "easeOutCubic"
              }
            ]
          },
          {
            "id": "subtitle",
            "type": "text",
            "position": { "x": 460, "y": 540 },
            "size": { "width": 1000, "height": 100 },
            "props": {
              "text": "{{subtitle}}",
              "fontSize": 80,
              "fontWeight": "900",
              "color": "#d946ef",
              "textAlign": "center",
              "letterSpacing": 12
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInUp",
                "delay": 40,
                "duration": 25,
                "easing": "easeOutBack"
              }
            ]
          },
          {
            "id": "tagline",
            "type": "text",
            "position": { "x": 560, "y": 680 },
            "size": { "width": 800, "height": 50 },
            "props": {
              "text": "{{tagline}}",
              "fontSize": 28,
              "fontWeight": "500",
              "color": "#c0a0ff",
              "textAlign": "center",
              "letterSpacing": 4
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 60,
                "duration": 20,
                "easing": "easeOutCubic"
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": { "x": 1520, "y": 20 },
            "size": { "width": 380, "height": 60 },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7
            }
          }
        ]
      }
    ]
  }
}
