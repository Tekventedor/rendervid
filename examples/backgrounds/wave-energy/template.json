{
  "name": "Wave Energy",
  "description": "High-energy wave background with vibrant purple/pink colors and waves from both top and bottom. Perfect for tech, gaming, and energetic content.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 5
  },
  "inputs": [
    {
      "key": "title",
      "type": "string",
      "label": "Main Title (First Line)",
      "required": true,
      "default": "UNLEASH"
    },
    {
      "key": "subtitle",
      "type": "string",
      "label": "Subtitle (Second Line)",
      "required": true,
      "default": "THE POWER"
    },
    {
      "key": "tagline",
      "type": "string",
      "label": "Tagline",
      "required": false,
      "default": "Next Generation Technology"
    },
    {
      "key": "waveColors",
      "type": "array",
      "label": "Wave Colors",
      "required": false,
      "default": [
        "#8b5cf6",
        "#d946ef",
        "#ec4899"
      ],
      "description": "Array of hex color codes for wave layers"
    },
    {
      "key": "waveSpeed",
      "type": "number",
      "label": "Wave Speed",
      "required": false,
      "default": 0.8,
      "min": 0.3,
      "max": 2
    },
    {
      "key": "waveCount",
      "type": "number",
      "label": "Wave Count",
      "required": false,
      "default": 3,
      "min": 1,
      "max": 3
    },
    {
      "key": "amplitude",
      "type": "number",
      "label": "Wave Amplitude",
      "required": false,
      "default": 70,
      "min": 40,
      "max": 120
    }
  ],
  "defaults": {
    "title": "UNLEASH",
    "subtitle": "THE POWER",
    "tagline": "Next Generation Technology",
    "waveColors": [
      "#8b5cf6",
      "#d946ef",
      "#ec4899"
    ],
    "waveSpeed": 0.8,
    "waveCount": 3,
    "amplitude": 70
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 150,
        "layers": [
          {
            "id": "background",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "shape": "rectangle",
              "fill": "#0f0a1e"
            }
          },
          {
            "id": "wave-background",
            "type": "custom",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "customComponent": {
              "name": "WaveBackground",
              "props": {
                "frame": 0,
                "fps": 30,
                "colors": [
                  "#8b5cf6",
                  "#d946ef",
                  "#ec4899"
                ],
                "speed": 0.8,
                "waveCount": 3,
                "amplitude": 70,
                "frequency": 0.02,
                "direction": "both",
                "opacity": 1,
                "width": "100%",
                "height": "100%"
              }
            }
          },
          {
            "id": "title",
            "type": "text",
            "position": {
              "x": 460,
              "y": 380
            },
            "size": {
              "width": 1000,
              "height": 140
            },
            "props": {
              "text": "{{title}}",
              "fontSize": 120,
              "fontWeight": "900",
              "color": "#ffffff",
              "textAlign": "center",
              "letterSpacing": 16,
              "textShadow": "0 4px 30px rgba(139, 92, 246, 0.8)"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 20,
                "duration": 30,
                "easing": "easeOutCubic"
              }
            ]
          },
          {
            "id": "subtitle",
            "type": "text",
            "position": {
              "x": 460,
              "y": 540
            },
            "size": {
              "width": 1000,
              "height": 100
            },
            "props": {
              "text": "{{subtitle}}",
              "fontSize": 80,
              "fontWeight": "900",
              "color": "#d946ef",
              "textAlign": "center",
              "letterSpacing": 12
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInUp",
                "delay": 40,
                "duration": 25,
                "easing": "easeOutBack"
              }
            ]
          },
          {
            "id": "tagline",
            "type": "text",
            "position": {
              "x": 560,
              "y": 680
            },
            "size": {
              "width": 800,
              "height": 50
            },
            "props": {
              "text": "{{tagline}}",
              "fontSize": 28,
              "fontWeight": "500",
              "color": "#c0a0ff",
              "textAlign": "center",
              "letterSpacing": 4
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 60,
                "duration": 20,
                "easing": "easeOutCubic"
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": {
              "x": 1520,
              "y": 20
            },
            "size": {
              "width": 380,
              "height": 60
            },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7
            }
          }
        ]
      }
    ]
  },
  "customComponents": {
    "WaveBackground": {
      "type": "inline",
      "code": "function WaveBackground(props) { var w = props.layerSize ? props.layerSize.width : 1920; var h = props.layerSize ? props.layerSize.height : 1080; var frame = props.frame || 0; var fps = props.fps || 30; var t = frame / fps; var colors = props.colors || ['#0ea5e9', '#06b6d4', '#14b8a6']; var speed = props.speed || 0.3; var waveCount = Math.min(props.waveCount || 3, colors.length); var amp = props.amplitude || 60; var freq = props.frequency || 0.02; var dir = props.direction || 'bottom'; var opacity = props.opacity !== undefined ? props.opacity : 1; var paths = []; for (var i = 0; i < waveCount; i++) { var baseY = dir === 'both' ? (i % 2 === 0 ? h * 0.7 + i * 40 : h * 0.2 - i * 20) : h * 0.55 + i * 80; var d = 'M0,' + baseY; for (var x = 0; x <= w; x += 20) { var y = baseY + Math.sin(x * freq + t * speed * (2 + i * 0.5) + i * 2) * amp * (1 - i * 0.15); y += Math.sin(x * freq * 0.5 + t * speed * 1.5 + i * 3) * amp * 0.3; d += ' L' + x + ',' + y; } if (dir === 'both' && i % 2 !== 0) { d += ' L' + w + ',0 L0,0 Z'; } else { d += ' L' + w + ',' + h + ' L0,' + h + ' Z'; } paths.push(React.createElement('path', { key: i, d: d, fill: colors[i % colors.length], opacity: 0.6 - i * 0.1 })); } return React.createElement('svg', { width: w, height: h, style: { position: 'absolute', top: 0, left: 0, opacity: opacity } }, paths); }",
      "description": "Animated wave pattern background"
    }
  }
}
