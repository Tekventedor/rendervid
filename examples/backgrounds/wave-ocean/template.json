{
  "name": "Wave Ocean",
  "description": "Serene ocean wave background with multiple flowing layers in blue and teal. Perfect for beach, summer, and ocean-themed content.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 6
  },
  "inputs": [
    {
      "key": "title",
      "type": "string",
      "label": "Main Title",
      "required": true,
      "default": "ENDLESS SUMMER"
    },
    {
      "key": "subtitle",
      "type": "string",
      "label": "Subtitle",
      "required": false,
      "default": "Dive into paradise"
    },
    {
      "key": "waveColors",
      "type": "array",
      "label": "Wave Colors",
      "required": false,
      "default": ["#0ea5e9", "#06b6d4", "#14b8a6"],
      "description": "Array of hex color codes for wave layers"
    },
    {
      "key": "waveSpeed",
      "type": "number",
      "label": "Wave Speed",
      "required": false,
      "default": 0.3,
      "min": 0.1,
      "max": 2.0
    },
    {
      "key": "waveCount",
      "type": "number",
      "label": "Wave Count",
      "required": false,
      "default": 3,
      "min": 1,
      "max": 3
    },
    {
      "key": "amplitude",
      "type": "number",
      "label": "Wave Amplitude",
      "required": false,
      "default": 60,
      "min": 20,
      "max": 120
    }
  ],
  "defaults": {
    "title": "ENDLESS SUMMER",
    "subtitle": "Dive into paradise",
    "waveColors": ["#0ea5e9", "#06b6d4", "#14b8a6"],
    "waveSpeed": 0.3,
    "waveCount": 3,
    "amplitude": 60
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 180,
        "layers": [
          {
            "id": "background",
            "type": "shape",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 1920, "height": 1080 },
            "props": {
              "shape": "rectangle",
              "fill": "#0a1929"
            }
          },
          {
            "id": "wave-background",
            "type": "custom",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 1920, "height": 1080 },
            "customComponent": {
              "name": "WaveBackground",
              "props": {
                "frame": 0,
                "fps": 30,
                "colors": ["#0ea5e9", "#06b6d4", "#14b8a6"],
                "speed": 0.3,
                "waveCount": 3,
                "amplitude": 60,
                "frequency": 0.02,
                "direction": "bottom",
                "opacity": 1,
                "width": "100%",
                "height": "100%"
              }
            }
          },
          {
            "id": "title",
            "type": "text",
            "position": { "x": 360, "y": 420 },
            "size": { "width": 1200, "height": 150 },
            "props": {
              "text": "{{title}}",
              "fontSize": 110,
              "fontWeight": "900",
              "color": "#ffffff",
              "textAlign": "center",
              "letterSpacing": 18,
              "textShadow": "0 4px 30px rgba(6, 182, 212, 0.8)"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 30,
                "duration": 40,
                "easing": "easeOutCubic"
              }
            ]
          },
          {
            "id": "subtitle",
            "type": "text",
            "position": { "x": 560, "y": 600 },
            "size": { "width": 800, "height": 70 },
            "props": {
              "text": "{{subtitle}}",
              "fontSize": 42,
              "fontWeight": "300",
              "color": "#7dd3fc",
              "textAlign": "center",
              "letterSpacing": 6,
              "fontFamily": "Inter, system-ui, sans-serif"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInUp",
                "delay": 60,
                "duration": 30,
                "easing": "easeOutCubic"
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": { "x": 1520, "y": 20 },
            "size": { "width": 380, "height": 60 },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7
            }
          }
        ]
      }
    ]
  }
}
