{
  "name": "Wave Ocean",
  "description": "Serene ocean wave background with multiple flowing layers in blue and teal. Perfect for beach, summer, and ocean-themed content.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 6
  },
  "inputs": [
    {
      "key": "title",
      "type": "string",
      "label": "Main Title",
      "required": true,
      "default": "ENDLESS SUMMER"
    },
    {
      "key": "subtitle",
      "type": "string",
      "label": "Subtitle",
      "required": false,
      "default": "Dive into paradise"
    },
    {
      "key": "waveColors",
      "type": "array",
      "label": "Wave Colors",
      "required": false,
      "default": ["#0ea5e9", "#06b6d4", "#14b8a6"],
      "description": "Array of hex color codes for wave layers"
    },
    {
      "key": "waveSpeed",
      "type": "number",
      "label": "Wave Speed",
      "required": false,
      "default": 0.3,
      "min": 0.1,
      "max": 2.0
    },
    {
      "key": "waveCount",
      "type": "number",
      "label": "Wave Count",
      "required": false,
      "default": 3,
      "min": 1,
      "max": 3
    },
    {
      "key": "amplitude",
      "type": "number",
      "label": "Wave Amplitude",
      "required": false,
      "default": 60,
      "min": 20,
      "max": 120
    }
  ],
  "defaults": {
    "title": "ENDLESS SUMMER",
    "subtitle": "Dive into paradise",
    "waveColors": ["#0ea5e9", "#06b6d4", "#14b8a6"],
    "waveSpeed": 0.3,
    "waveCount": 3,
    "amplitude": 60
  }
}
