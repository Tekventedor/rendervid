{
  "name": "Complex Motion",
  "version": "2.0.0",
  "output": {"type": "video", "width": 1920, "height": 1080, "fps": 30, "duration": 5},
  "customComponents": {
    "ComplexMotion": {
      "type": "inline",
      "description": "Sphere orbits elliptically (200px wide, 100px tall) around center (960,440) with 4s period; pulsing scale simulates the original emphasis pulse animation",
      "code": "function(props){var f=props.frame,W=props.layerSize.width,H=props.layerSize.height,PI=Math.PI,t=f*2*PI/120,x=960+200*Math.sin(t),y=440+100*Math.cos(t),s=1+0.2*Math.sin(f*PI/15),r=30*s;return React.createElement('svg',{xmlns:'http://www.w3.org/2000/svg',width:W,height:H,style:{position:'absolute',top:0,left:0}},React.createElement('ellipse',{cx:960,cy:440,rx:204,ry:104,fill:'none',stroke:'#440044',strokeWidth:3,opacity:0.6,strokeDasharray:'12 8'}),React.createElement('ellipse',{cx:x,cy:y,rx:r*0.6,ry:r*0.6,fill:'#ff00ff',opacity:0.3}),React.createElement('ellipse',{cx:x,cy:y,rx:r,ry:r,fill:'#ff00ff',style:{filter:'drop-shadow(0 0 20px #ff00ff)'}}),React.createElement('text',{x:80,y:900,fill:'#aa00aa',fontSize:28,fontFamily:'monospace'},'Circular orbit 200\u00d7100px \u2014 period 4s \u2014 with pulse'));}"
    }
  },
  "composition": {
    "scenes": [{
      "id": "main",
      "startFrame": 0,
      "endFrame": 150,
      "backgroundColor": "#0a0a1a",
      "layers": [
        {
          "id": "title",
          "type": "text",
          "position": {"x": 160, "y": 50},
          "size": {"width": 1600, "height": 100},
          "props": {"text": "Complex Motion - Orbital Behaviors", "fontSize": 48, "color": "#ff00ff", "fontWeight": "bold", "textAlign": "center"},
          "animations": [{"type": "entrance", "effect": "fadeIn", "duration": 20}]
        },
        {
          "id": "spiral",
          "type": "custom",
          "position": {"x": 0, "y": 0},
          "size": {"width": 1920, "height": 1080},
          "customComponent": {"name": "ComplexMotion", "props": {}}
        }
      ]
    }]
  }
}
