{
  "name": "Blog Promo",
  "description": "Blog post promotion card with featured image, title, and CTA.",
  "version": "1.0.0",
  "output": { "type": "video", "width": 1920, "height": 1080, "fps": 30, "duration": 6 },
  "inputs": [
    { "key": "category", "type": "string", "label": "Category", "required": false, "default": "MARKETING" },
    { "key": "title", "type": "string", "label": "Blog Title", "required": true, "default": "10 Strategies to Boost Your Social Media Engagement" },
    { "key": "excerpt", "type": "string", "label": "Excerpt", "required": false, "default": "Discover proven tactics to increase your audience engagement." },
    { "key": "cta", "type": "string", "label": "CTA", "required": false, "default": "Read Article" }
  ],
  "defaults": { "category": "MARKETING", "title": "10 Strategies to Boost Your Social Media Engagement", "excerpt": "Discover proven tactics to increase your audience engagement.", "cta": "Read Article" },
  "composition": {
    "scenes": [{
      "id": "main", "startFrame": 0, "endFrame": 180,
      "layers": [
        { "id": "bg", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#ffffff" } },
        { "id": "content-bg", "type": "shape", "position": { "x": 0, "y": 600 }, "size": { "width": 1920, "height": 480 }, "props": { "shape": "rectangle", "fill": "#ffffff" } },
        { "id": "category", "type": "text", "position": { "x": 100, "y": 660 }, "size": { "width": 400, "height": 40 }, "props": { "text": "{{category}}", "fontSize": 20, "fontWeight": "600", "color": "#3b82f6", "textAlign": "left" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 20, "duration": 20 }] },
        { "id": "title", "type": "text", "position": { "x": 100, "y": 740 }, "size": { "width": 1600, "height": 120 }, "props": { "text": "{{title}}", "fontSize": 56, "fontWeight": "bold", "color": "#1f2937", "textAlign": "left" }, "animations": [{ "type": "entrance", "effect": "slideInUp", "delay": 30, "duration": 25 }] },
        { "id": "excerpt", "type": "text", "position": { "x": 100, "y": 880 }, "size": { "width": 1400, "height": 60 }, "props": { "text": "{{excerpt}}", "fontSize": 28, "color": "#6b7280", "textAlign": "left" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 45, "duration": 20 }] },
        { "id": "cta", "type": "text", "position": { "x": 100, "y": 980 }, "size": { "width": 300, "height": 50 }, "props": { "text": "{{cta}}", "fontSize": 24, "fontWeight": "600", "color": "#3b82f6", "textAlign": "left" }, "animations": [{ "type": "entrance", "effect": "slideInLeft", "delay": 55, "duration": 20 }] }
      ]
    }]
  }
}
