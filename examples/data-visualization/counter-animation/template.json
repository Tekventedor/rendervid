              "x": 680,
              "y": 400
            },
            "size": {
              "width": 2,
              "height": 200
            },
            "opacity": 0.3,
            "props": {
              "shape": "rectangle",
              "fill": "#64748b"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 55,
                "duration": 20
              }
            ]
          },
          {
            "id": "stat2-value",
            "type": "text",
            "position": {
              "x": 720,
              "y": 400
            },
            "size": {
              "width": 480,
              "height": 150
            },
            "props": {
              "text": "{{stat2Value}}",
              "fontSize": 96,
              "fontWeight": "800",
              "color": "#8b5cf6",
              "textAlign": "center",
              "fontFamily": "Inter, system-ui, sans-serif"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 35,
                "duration": 30,
                "easing": "easeOutBack"
              }
            ]
          },
          {
            "id": "stat2-label",
            "type": "text",
            "position": {
              "x": 720,
              "y": 560
            },
            "size": {
              "width": 480,
              "height": 50
            },
            "props": {
              "text": "{{stat2Label}}",
              "fontSize": 28,
              "fontWeight": "500",
              "color": "#94a3b8",
              "textAlign": "center",
              "fontFamily": "Inter, system-ui, sans-serif"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 55,
                "duration": 20
              }
            ]
          },
          {
            "id": "divider2",
            "type": "shape",
            "position": {
              "x": 1240,
              "y": 400
            },
            "size": {
              "width": 2,
              "height": 200
            },
            "opacity": 0.3,
            "props": {
              "shape": "rectangle",
              "fill": "#64748b"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 70,
                "duration": 20
              }
            ]
          },
          {
            "id": "stat3-value",
            "type": "text",
            "position": {
              "x": 1280,
              "y": 400
            },
            "size": {
              "width": 480,
              "height": 150
            },
            "props": {
              "text": "{{stat3Value}}",
              "fontSize": 96,
              "fontWeight": "800",
              "color": "#22c55e",
              "textAlign": "center",
              "fontFamily": "Inter, system-ui, sans-serif"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 50,
                "duration": 30,
                "easing": "easeOutBack"
              }
            ]
          },
          {
            "id": "stat3-label",
            "type": "text",
            "position": {
              "x": 1280,
              "y": 560
            },
            "size": {
              "width": 480,
              "height": 50
            },
            "props": {
              "text": "{{stat3Label}}",
              "fontSize": 28,
              "fontWeight": "500",
              "color": "#94a3b8",
              "textAlign": "center",
              "fontFamily": "Inter, system-ui, sans-serif"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 70,
                "duration": 20
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": {
              "x": 1520,
              "y": 20
            },
            "size": {
              "width": 380,
              "height": 60
            },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7,
              "textShadow": "0 2px 4px rgba(0,0,0,0.5)"
            }
          }
        ]
      }
    ]
  }
}
