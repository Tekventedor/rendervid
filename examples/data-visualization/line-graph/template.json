{
  "name": "Line Graph",
  "description": "Animated line graph with trend visualization.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 5
  },
  "inputs": [
    {
      "key": "title",
      "type": "string",
      "label": "Chart Title",
      "required": true,
      "default": "Growth Over Time"
    },
    {
      "key": "subtitle",
      "type": "string",
      "label": "Subtitle",
      "required": false,
      "default": "Monthly Active Users"
    },
    {
      "key": "metric",
      "type": "string",
      "label": "Key Metric",
      "required": false,
      "default": "+127%"
    },
    {
      "key": "metricLabel",
      "type": "string",
      "label": "Metric Label",
      "required": false,
      "default": "Year over Year"
    },
    {
      "key": "primaryColor",
      "type": "color",
      "label": "Primary Color",
      "required": false,
      "default": "#10b981"
    },
    {
      "key": "backgroundColor",
      "type": "color",
      "label": "Background Color",
      "required": false,
      "default": "#0f172a"
    }
  ],
  "defaults": {
    "title": "Growth Over Time",
    "subtitle": "Monthly Active Users",
    "metric": "+127%",
    "metricLabel": "Year over Year",
    "primaryColor": "#10b981",
    "backgroundColor": "#0f172a"
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 150,
        "layers": [
          {
            "id": "background",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "shape": "rectangle",
              "fill": "{{backgroundColor}}"
            }
          },
          {
            "id": "title",
            "type": "text",
            "position": {
              "x": 160,
              "y": 80
            },
            "size": {
              "width": 800,
              "height": 70
            },
            "props": {
              "text": "{{title}}",
              "fontSize": 48,
              "fontWeight": "bold",
              "color": "#f8fafc",
              "textAlign": "left",
              "fontFamily": "Inter, system-ui, sans-serif"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 0,
                "duration": 20
              }
            ]
          },
          {
            "id": "subtitle",
            "type": "text",
            "position": {
              "x": 160,
              "y": 155
            },
            "size": {
              "width": 600,
              "height": 40
            },
            "props": {
              "text": "{{subtitle}}",
              "fontSize": 24,
              "fontWeight": "normal",
              "color": "#94a3b8",
              "textAlign": "left",
              "fontFamily": "Inter, system-ui, sans-serif"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 15,
                "duration": 20
              }
            ]
          },
          {
            "id": "chart-area",
            "type": "shape",
            "position": {
              "x": 160,
              "y": 280
            },
            "size": {
              "width": 1200,
              "height": 500
            },
            "props": {
              "shape": "rectangle",
              "fill": "#1e293b",
              "borderRadius": 16
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 25,
                "duration": 20
