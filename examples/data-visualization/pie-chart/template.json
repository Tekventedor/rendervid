{
  "name": "Pie Chart",
  "description": "Animated pie chart with segment reveals.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 5
  },
  "inputs": [
    {
      "key": "title",
      "type": "string",
      "label": "Chart Title",
      "required": true,
      "default": "Revenue Distribution"
    },
    {
      "key": "segment1Label",
      "type": "string",
      "label": "Segment 1 Label",
      "required": false,
      "default": "Product Sales"
    },
    {
      "key": "segment1Value",
      "type": "string",
      "label": "Segment 1 Value",
      "required": false,
      "default": "45%"
    },
    {
      "key": "segment2Label",
      "type": "string",
      "label": "Segment 2 Label",
      "required": false,
      "default": "Services"
    },
    {
      "key": "segment2Value",
      "type": "string",
      "label": "Segment 2 Value",
      "required": false,
      "default": "35%"
    },
    {
      "key": "segment3Label",
      "type": "string",
      "label": "Segment 3 Label",
      "required": false,
      "default": "Licensing"
    },
    {
      "key": "segment3Value",
      "type": "string",
      "label": "Segment 3 Value",
      "required": false,
      "default": "20%"
    },
    {
      "key": "backgroundColor",
      "type": "color",
      "label": "Background Color",
      "required": false,
      "default": "#09090b"
    }
  ],
  "defaults": {
    "title": "Revenue Distribution",
    "segment1Label": "Product Sales",
    "segment1Value": "45%",
    "segment2Label": "Services",
    "segment2Value": "35%",
    "segment3Label": "Licensing",
    "segment3Value": "20%",
    "backgroundColor": "#09090b"
  },
