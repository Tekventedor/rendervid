{
  "name": "Product Comparison",
  "description": "Side-by-side feature comparison of two products or plans.",
  "version": "1.0.0",
  "output": { "type": "video", "width": 1920, "height": 1080, "fps": 30, "duration": 8 },
  "inputs": [
    { "key": "header", "type": "string", "label": "Header", "required": true, "default": "Choose What's Right for You" },
    { "key": "product1Name", "type": "string", "label": "Product 1 Name", "required": true, "default": "Basic Plan" },
    { "key": "product1Features", "type": "string", "label": "Product 1 Features", "required": false, "default": "5 Users • 10GB Storage • Email Support" },
    { "key": "product2Name", "type": "string", "label": "Product 2 Name", "required": true, "default": "Pro Plan" },
    { "key": "product2Features", "type": "string", "label": "Product 2 Features", "required": false, "default": "Unlimited Users • 100GB • Priority Support" }
  ],
  "defaults": { "header": "Choose What's Right for You", "product1Name": "Basic Plan", "product1Features": "5 Users • 10GB Storage • Email Support", "product2Name": "Pro Plan", "product2Features": "Unlimited Users • 100GB • Priority Support" },
  "composition": {
    "scenes": [{
      "id": "main", "startFrame": 0, "endFrame": 240,
      "layers": [
        { "id": "bg", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#f8fafc" } },
        { "id": "header", "type": "text", "position": { "x": 260, "y": 60 }, "size": { "width": 1400, "height": 100 }, "props": { "text": "{{header}}", "fontSize": 56, "fontWeight": "bold", "color": "#1e293b", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "slideInDown", "delay": 0, "duration": 25 }] },
        { "id": "divider", "type": "shape", "position": { "x": 955, "y": 200 }, "size": { "width": 10, "height": 700 }, "props": { "shape": "rectangle", "fill": "#e2e8f0" }, "animations": [{ "type": "entrance", "effect": "scaleIn", "delay": 20, "duration": 25 }] },
        { "id": "left-bg", "type": "shape", "position": { "x": 100, "y": 220 }, "size": { "width": 800, "height": 660 }, "props": { "shape": "rectangle", "fill": "#ffffff" }, "animations": [{ "type": "entrance", "effect": "slideInLeft", "delay": 25, "duration": 25 }] },
        { "id": "left-name", "type": "text", "position": { "x": 150, "y": 300 }, "size": { "width": 700, "height": 80 }, "props": { "text": "{{product1Name}}", "fontSize": 42, "fontWeight": "bold", "color": "#1e293b", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 40, "duration": 20 }] },
        { "id": "left-features", "type": "text", "position": { "x": 150, "y": 450 }, "size": { "width": 700, "height": 300 }, "props": { "text": "{{product1Features}}", "fontSize": 26, "color": "#475569", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 50, "duration": 20 }] },
        { "id": "right-bg", "type": "shape", "position": { "x": 1020, "y": 200 }, "size": { "width": 800, "height": 700 }, "props": { "shape": "rectangle", "fill": "#3b82f6" }, "animations": [{ "type": "entrance", "effect": "slideInRight", "delay": 25, "duration": 25 }] },
        { "id": "badge", "type": "text", "position": { "x": 1270, "y": 230 }, "size": { "width": 300, "height": 40 }, "props": { "text": "RECOMMENDED", "fontSize": 18, "fontWeight": "bold", "color": "#bfdbfe", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "scaleIn", "delay": 45, "duration": 20 }] },
        { "id": "right-name", "type": "text", "position": { "x": 1070, "y": 320 }, "size": { "width": 700, "height": 80 }, "props": { "text": "{{product2Name}}", "fontSize": 42, "fontWeight": "bold", "color": "#ffffff", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 45, "duration": 20 }] },
        { "id": "right-features", "type": "text", "position": { "x": 1070, "y": 470 }, "size": { "width": 700, "height": 300 }, "props": { "text": "{{product2Features}}", "fontSize": 26, "color": "#dbeafe", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 55, "duration": 20 }] }
      ]
    }]
  }
}
