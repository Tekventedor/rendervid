            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "shape": "rectangle",
              "fill": "#fef3c7"
            }
          },
          {
            "id": "inner",
            "type": "shape",
            "position": {
              "x": 100,
              "y": 80
            },
            "size": {
              "width": 1720,
              "height": 920
            },
            "props": {
              "shape": "rectangle",
              "fill": "#ffffff"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 0,
                "duration": 20
              }
            ]
          },
          {
            "id": "border",
            "type": "shape",
            "position": {
              "x": 130,
              "y": 110
            },
            "size": {
              "width": 1660,
              "height": 860
            },
            "props": {
              "shape": "rectangle",
              "fill": "#d97706"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 15,
                "duration": 25
              }
