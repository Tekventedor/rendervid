{
  "name": "Certificate",
  "description": "Achievement certificate for course completion or awards.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 8
  },
  "inputs": [
    {
      "key": "certificateType",
      "type": "string",
      "label": "Certificate Type",
      "required": false,
      "default": "of Completion"
    },
    {
      "key": "recipientName",
      "type": "string",
      "label": "Recipient Name",
      "required": true,
      "default": "John Smith"
    },
    {
      "key": "achievement",
      "type": "string",
      "label": "Achievement",
      "required": true,
      "default": "for successfully completing the Advanced Web Development Course"
    },
    {
      "key": "date",
      "type": "string",
      "label": "Date",
      "required": false,
      "default": "January 15, 2024"
    }
  ],
  "defaults": {
    "certificateType": "of Completion",
    "recipientName": "John Smith",
    "achievement": "for successfully completing the Advanced Web Development Course",
    "date": "January 15, 2024"
  },
  "composition": {
