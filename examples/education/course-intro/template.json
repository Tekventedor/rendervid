{
  "name": "Course Intro",
  "description": "Professional course introduction featuring course title and instructor.",
  "version": "1.0.0",
  "output": { "type": "video", "width": 1920, "height": 1080, "fps": 30, "duration": 8 },
  "inputs": [
    { "key": "courseTitle", "type": "string", "label": "Course Title", "required": true, "default": "Complete Python Masterclass" },
    { "key": "description", "type": "string", "label": "Description", "required": false, "default": "From beginner to advanced with real-world projects" },
    { "key": "instructorName", "type": "string", "label": "Instructor Name", "required": false, "default": "Dr. Alex Thompson" },
    { "key": "duration", "type": "string", "label": "Duration", "required": false, "default": "12 hours" }
  ],
  "defaults": { "courseTitle": "Complete Python Masterclass", "description": "From beginner to advanced with real-world projects", "instructorName": "Dr. Alex Thompson", "duration": "12 hours" },
  "composition": { "scenes": [{ "id": "main", "startFrame": 0, "endFrame": 240, "layers": [
    { "id": "bg", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#1e1b4b" } },
    { "id": "welcome", "type": "text", "position": { "x": 230, "y": 160 }, "size": { "width": 500, "height": 50 }, "props": { "text": "WELCOME TO", "fontSize": 24, "fontWeight": "600", "color": "#818cf8", "textAlign": "left" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 0, "duration": 20 }] },
    { "id": "title", "type": "text", "position": { "x": 230, "y": 280 }, "size": { "width": 1000, "height": 150 }, "props": { "text": "{{courseTitle}}", "fontSize": 72, "fontWeight": "bold", "color": "#ffffff", "textAlign": "left" }, "animations": [{ "type": "entrance", "effect": "slideInLeft", "delay": 15, "duration": 30 }] },
    { "id": "description", "type": "text", "position": { "x": 230, "y": 480 }, "size": { "width": 900, "height": 80 }, "props": { "text": "{{description}}", "fontSize": 28, "color": "#c7d2fe", "textAlign": "left" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 35, "duration": 25 }] },
    { "id": "instructor", "type": "text", "position": { "x": 230, "y": 700 }, "size": { "width": 500, "height": 50 }, "props": { "text": "{{instructorName}}", "fontSize": 28, "fontWeight": "600", "color": "#ffffff", "textAlign": "left" }, "animations": [{ "type": "entrance", "effect": "slideInLeft", "delay": 50, "duration": 25 }] },
    { "id": "duration", "type": "text", "position": { "x": 1500, "y": 850 }, "size": { "width": 300, "height": 50 }, "props": { "text": "{{duration}}", "fontSize": 22, "fontWeight": "600", "color": "#818cf8", "textAlign": "right" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 60, "duration": 20 }] }
  ]}]}
}
