{
  "name": "Glitch Reveal",
  "description": "Dramatic reveal effect where text starts heavily glitched and gradually becomes clear through multiple glitch type transitions.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 6
  },
  "inputs": [
    {
      "key": "text",
      "type": "string",
      "label": "Initial Text",
      "required": true,
      "default": "TRANSMISSION INCOMING"
    },
    {
      "key": "finalText",
      "type": "string",
      "label": "Final Text",
      "required": true,
      "default": "MESSAGE DECODED"
    },
    {
      "key": "backgroundColor",
      "type": "color",
      "label": "Background Color",
      "required": false,
      "default": "#000000"
    },
    {
      "key": "textColor",
      "type": "color",
      "label": "Text Color",
      "required": false,
      "default": "#ffffff"
    }
  ],
  "defaults": {
    "text": "TRANSMISSION INCOMING",
    "finalText": "MESSAGE DECODED",
    "backgroundColor": "#000000",
    "textColor": "#ffffff"
  },
  "customComponents": {
    "GlitchRevealText": {
      "type": "inline",
      "code": "function GlitchRevealText(props) { var frame = props.frame || 0; var text = props.text || ''; var finalText = props.finalText || text; var fontSize = props.fontSize || 80; var color = props.color || '#ffffff'; var duration = 120; var progress = Math.min(1, frame / duration); var chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%&'; var displayText = progress < 0.5 ? text : finalText; var glitchIntensity = progress < 0.5 ? 1 - progress * 1.5 : Math.max(0, 1 - (progress - 0.5) * 3); var result = ''; for (var i = 0; i < displayText.length; i++) { if (Math.random() < glitchIntensity && displayText[i] !== ' ') { result += chars[Math.floor(Math.random() * chars.length)]; } else { result += displayText[i]; } } var offsetX = glitchIntensity > 0.3 ? (Math.random() - 0.5) * 10 : 0; return React.createElement('div', { style: { fontSize: fontSize + 'px', fontWeight: '900', color: color, textAlign: 'center', fontFamily: 'monospace', letterSpacing: '8px', transform: 'translateX(' + offsetX + 'px)' } }, result); }",
      "description": "Glitch text reveal effect"
    }
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 180,
        "layers": [
          {
            "id": "bg",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "shape": "rectangle",
              "fill": "{{backgroundColor}}"
            }
          },
          {
            "id": "static-noise",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "opacity": 0.03,
            "props": {
              "shape": "rectangle",
              "fill": "#ffffff"
            }
          },
          {
            "id": "reveal-text",
            "type": "custom",
            "position": {
              "x": 160,
              "y": 420
            },
            "size": {
              "width": 1600,
              "height": 150
            },
            "customComponent": {
              "name": "GlitchRevealText",
              "props": {
                "text": "{{text}}",
                "finalText": "{{finalText}}",
                "fontSize": 80,
                "color": "{{textColor}}"
              }
            }
          },
          {
            "id": "status-text",
            "type": "text",
            "position": {
              "x": 660,
              "y": 600
            },
            "size": {
              "width": 600,
              "height": 40
            },
            "props": {
              "text": "DECODING...",
              "fontSize": 18,
              "color": "{{textColor}}",
              "textAlign": "center",
              "fontFamily": "monospace",
              "letterSpacing": 6,
              "opacity": 0.5
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 10,
                "duration": 20
              },
              {
                "type": "exit",
                "effect": "fadeOut",
                "delay": 100,
                "duration": 20
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": {
              "x": 1520,
              "y": 20
            },
            "size": {
              "width": 380,
              "height": 60
            },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7
            }
          }
        ]
      }
    ]
  }
}
