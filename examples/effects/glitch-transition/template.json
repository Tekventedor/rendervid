{
  "name": "Glitch Transition",
  "description": "Multi-layer text composition with different glitch frequencies and types creating a dynamic, chaotic visual experience.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 6
  },
  "inputs": [
    {
      "key": "line1",
      "type": "string",
      "label": "Line 1",
      "required": true,
      "default": "DIGITAL"
    },
    {
      "key": "line2",
      "type": "string",
      "label": "Line 2 (Main)",
      "required": true,
      "default": "CHAOS"
    },
    {
      "key": "line3",
      "type": "string",
      "label": "Line 3",
      "required": true,
      "default": "THEORY"
    },
    {
      "key": "tagline",
      "type": "string",
      "label": "Tagline",
      "required": false,
      "default": "Where order meets disorder"
    },
    {
      "key": "backgroundColor",
      "type": "color",
      "label": "Background Color",
      "required": false,
      "default": "#0a0a0a"
    }
  ],
  "defaults": {
    "line1": "DIGITAL",
    "line2": "CHAOS",
    "line3": "THEORY",
    "tagline": "Where order meets disorder",
    "backgroundColor": "#0a0a0a"
  },
  "customComponents": {
    "GlitchText": {
      "type": "inline",
      "code": "function GlitchText(props) { var frame = props.frame || 0; var text = props.text || 'GLITCH'; var fontSize = props.fontSize || 72; var color = props.color || '#ffffff'; var glitchFreq = props.glitchFreq || 0.3; var intensity = Math.sin(frame * glitchFreq) > 0.5 ? 1 : 0; var offsetR = intensity * Math.sin(frame * 5.7) * 6; var offsetB = intensity * Math.sin(frame * 4.3) * -5; var base = { position: 'absolute', top: 0, left: 0, width: '100%', fontSize: fontSize + 'px', fontWeight: '900', textAlign: 'center', fontFamily: 'monospace', letterSpacing: '10px' }; return React.createElement('div', { style: { position: 'relative', width: '100%', height: '100%' } }, React.createElement('div', { key: 'r', style: Object.assign({}, base, { color: 'rgba(255,0,0,0.6)', transform: 'translateX(' + offsetR + 'px)', mixBlendMode: 'screen' }) }, text), React.createElement('div', { key: 'b', style: Object.assign({}, base, { color: 'rgba(0,0,255,0.6)', transform: 'translateX(' + offsetB + 'px)', mixBlendMode: 'screen' }) }, text), React.createElement('div', { key: 'm', style: Object.assign({}, base, { color: color }) }, text) ); }",
      "description": "Glitch text with RGB split"
    }
  },
  "composition": {
    "scenes": [
      {
        "id": "scene1",
        "startFrame": 0,
        "endFrame": 60,
        "layers": [
          {
            "id": "bg1",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "shape": "rectangle",
              "fill": "{{backgroundColor}}"
            }
          },
          {
            "id": "line1-text",
            "type": "custom",
            "position": {
              "x": 160,
              "y": 300
            },
            "size": {
              "width": 1600,
              "height": 100
            },
            "customComponent": {
              "name": "GlitchText",
              "props": {
                "text": "{{line1}}",
                "fontSize": 64,
                "color": "#888888",
                "glitchFreq": 0.2
              }
            }
          },
          {
            "id": "line2-text",
            "type": "custom",
            "position": {
              "x": 160,
              "y": 420
            },
            "size": {
              "width": 1600,
              "height": 150
            },
            "customComponent": {
              "name": "GlitchText",
              "props": {
                "text": "{{line2}}",
                "fontSize": 120,
                "color": "#ffffff",
                "glitchFreq": 0.35
              }
            }
          },
          {
            "id": "line3-text",
            "type": "custom",
            "position": {
              "x": 160,
              "y": 580
            },
            "size": {
              "width": 1600,
              "height": 100
            },
            "customComponent": {
              "name": "GlitchText",
              "props": {
                "text": "{{line3}}",
                "fontSize": 64,
                "color": "#888888",
                "glitchFreq": 0.25
              }
            }
          },
          {
            "id": "watermark",
            "type": "text",
            "position": {
              "x": 1520,
              "y": 20
            },
            "size": {
              "width": 380,
              "height": 60
            },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7
            }
          }
        ]
      },
      {
        "id": "scene2",
        "startFrame": 60,
        "endFrame": 180,
        "transition": {
          "type": "fade",
          "duration": 15
        },
        "layers": [
          {
            "id": "bg2",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "shape": "rectangle",
              "fill": "{{backgroundColor}}"
            }
          },
          {
            "id": "line2-big",
            "type": "custom",
            "position": {
              "x": 60,
              "y": 380
            },
            "size": {
              "width": 1800,
              "height": 180
            },
            "customComponent": {
              "name": "GlitchText",
              "props": {
                "text": "{{line2}}",
                "fontSize": 140,
                "color": "#ffffff",
                "glitchFreq": 0.4
              }
            }
          },
          {
            "id": "tagline",
            "type": "text",
            "position": {
              "x": 460,
              "y": 600
            },
            "size": {
              "width": 1000,
              "height": 50
            },
            "props": {
              "text": "{{tagline}}",
              "fontSize": 28,
              "color": "#666666",
              "textAlign": "center",
              "fontFamily": "monospace",
              "letterSpacing": 6
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 20,
                "duration": 30
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": {
              "x": 1520,
              "y": 20
            },
            "size": {
              "width": 380,
              "height": 60
            },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7
            }
          }
        ]
      }
    ]
  }
}
