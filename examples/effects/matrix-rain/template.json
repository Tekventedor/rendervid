{
  "name": "Matrix Digital Rain",
  "description": "Iconic Matrix-style digital rain effect with cascading green characters over a dark background. Features a custom animated rain component with centered glowing title text. Perfect for tech, hacker, or sci-fi themed content.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 8
  },
  "inputs": [
    {
      "key": "title",
      "type": "string",
      "label": "Main Title",
      "required": true,
      "default": "ENTER THE SYSTEM"
    },
    {
      "key": "subtitle",
      "type": "string",
      "label": "Subtitle",
      "required": false,
      "default": "The Matrix has you..."
    }
  ],
  "defaults": {
    "title": "ENTER THE SYSTEM",
    "subtitle": "The Matrix has you..."
  },
  "customComponents": {
    "MatrixRain": {
      "type": "inline",
      "code": "function MatrixRain(props) { var frame = props.frame || 0; var w = (props.layerSize && props.layerSize.width) || 1920; var h = (props.layerSize && props.layerSize.height) || 1080; var cols = 48; var colW = w / cols; var chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789@#$%^&*(){}[]|;:<>?/~'; var elements = []; for (var c = 0; c < cols; c++) { var seed = (c * 7 + 3) % 17; var speed = 2 + (seed % 5); var startOffset = (seed * 13) % 40; var numChars = 12 + (seed % 10); for (var r = 0; r < numChars; r++) { var yBase = ((frame + startOffset) * speed + r * 40) % (h + 400) - 200; var charIdx = (c * 31 + r * 7 + frame * 3 + seed) % chars.length; var brightness = 1 - (r / numChars); var green = Math.floor(100 + brightness * 155); var alpha = brightness * 0.9; if (r === 0) { alpha = 1; green = 255; } var style = { position: 'absolute', left: (c * colW + colW * 0.2) + 'px', top: yBase + 'px', color: r === 0 ? '#ffffff' : 'rgba(0,' + green + ',0,' + alpha + ')', fontSize: '18px', fontFamily: 'monospace', fontWeight: r === 0 ? '700' : '400', textShadow: r === 0 ? '0 0 10px #00ff00, 0 0 20px #00ff00' : '0 0 5px rgba(0,255,0,0.3)' }; elements.push(React.createElement('span', { key: c + '-' + r, style: style }, chars[charIdx])); } } return React.createElement('div', { style: { position: 'relative', width: '100%', height: '100%', overflow: 'hidden', background: 'transparent' } }, elements); }",
      "description": "Animated Matrix-style falling character rain effect"
    }
  },
