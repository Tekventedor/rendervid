{
  "name": "Particle Intro Animation",
  "description": "Particle-based intro animation with aurora background, floating particles with connections, and title text appearing through particles.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 6
  },
  "inputs": [
    {
      "key": "title",
      "type": "string",
      "label": "Title Text",
      "required": true,
      "default": "WELCOME"
    },
    {
      "key": "subtitle",
      "type": "string",
      "label": "Subtitle Text",
      "required": false,
      "default": "To the Future"
    },
    {
      "key": "particleColor",
      "type": "color",
      "label": "Particle Color",
      "required": false,
      "default": "#ffffff"
    },
    {
      "key": "particleCount",
      "type": "number",
      "label": "Particle Count",
      "required": false,
      "default": 80
    }
  ],
  "defaults": {
    "title": "WELCOME",
    "subtitle": "To the Future",
    "particleColor": "#ffffff",
    "particleCount": 80
  },
  "composition": {
    "scenes": [
      {
        "id": "intro",
        "startFrame": 0,
        "endFrame": 180,
        "layers": [
          {
            "id": "aurora-bg",
            "type": "custom",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 1920, "height": 1080 },
            "customComponent": {
              "name": "aurora-background",
              "props": {
                "frame": 0,
                "totalFrames": 180,
                "fps": 30,
                "colors": ["#667eea", "#764ba2", "#f093fb", "#4facfe"],
                "speed": 0.8,
                "blur": 50,
                "opacity": 0.6,
                "width": "100%",
                "height": "100%"
              }
            }
          },
          {
            "id": "particles",
            "type": "custom",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 1920, "height": 1080 },
            "customComponent": {
              "name": "particle-system",
              "props": {
                "frame": 0,
                "fps": 30,
                "count": "{{particleCount}}",
                "type": "circle",
                "color": "{{particleColor}}",
                "size": [2, 5],
                "speed": [0.5, 1.5],
                "direction": "random",
                "opacity": [0.4, 0.8],
                "wrap": true,
                "fadeIn": true,
                "connections": true,
                "connectionDistance": 120,
                "connectionColor": "{{particleColor}}",
                "connectionOpacity": 0.3,
                "connectionWidth": 1,
                "width": 1920,
                "height": 1080,
                "seed": 42
              }
            }
          },
          {
            "id": "title",
            "type": "text",
            "position": { "x": 160, "y": 420 },
            "size": { "width": 1600, "height": 120 },
            "props": {
              "text": "{{title}}",
              "fontSize": 96,
              "fontWeight": "800",
              "color": "#ffffff",
              "textAlign": "center",
              "fontFamily": "Inter, system-ui, sans-serif",
              "letterSpacing": 12,
              "textShadow": {
                "color": "rgba(0, 0, 0, 0.5)",
                "blur": 20,
                "offsetX": 0,
                "offsetY": 4
              }
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 45,
                "duration": 35,
                "easing": "easeOutBack"
              }
            ]
          },
          {
            "id": "subtitle",
            "type": "text",
            "position": { "x": 160, "y": 560 },
            "size": { "width": 1600, "height": 60 },
            "props": {
              "text": "{{subtitle}}",
              "fontSize": 32,
              "fontWeight": "normal",
              "color": "#e0e0e0",
              "textAlign": "center",
              "fontFamily": "Inter, system-ui, sans-serif",
              "letterSpacing": 6,
              "textShadow": {
                "color": "rgba(0, 0, 0, 0.4)",
                "blur": 10,
                "offsetX": 0,
                "offsetY": 2
              }
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 75,
                "duration": 30
              }
            ]
          }
        ]
      }
    ]
  }
}
