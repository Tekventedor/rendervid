    {
      "key": "beforeLabel",
      "type": "string",
      "label": "Before Label",
      "required": false,
      "default": "BEFORE"
    },
    {
      "key": "afterLabel",
      "type": "string",
      "label": "After Label",
      "required": false,
      "default": "AFTER"
