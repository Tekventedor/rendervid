{
  "name": "SVG Logo Reveal",
  "description": "Animated SVG drawing effect revealing a star logo path by path, perfect for logo reveals and brand animations.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 5
  },
  "inputs": [
    {
      "key": "title",
      "type": "string",
      "label": "Title Text",
      "required": false,
      "default": "YOUR BRAND"
    },
    {
      "key": "strokeColor",
      "type": "color",
      "label": "Stroke Color",
      "required": false,
      "default": "#ffd700"
    },
    {
      "key": "backgroundColor",
      "type": "color",
      "label": "Background Color",
      "required": false,
      "default": "#1a1a2e"
    }
  ],
  "defaults": {
    "title": "YOUR BRAND",
    "strokeColor": "#ffd700",
    "backgroundColor": "#1a1a2e"
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 150,
        "layers": [
          {
            "id": "background",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "shape": "rectangle",
              "fill": "{{backgroundColor}}"
            },
            "animations": []
          },
          {
            "id": "svg-drawing",
            "type": "custom",
            "position": {
              "x": 660,
              "y": 240
            },
            "size": {
              "width": 600,
              "height": 600
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 5,
                "duration": 10
              }
            ],
            "customComponent": {
              "name": "SVGDrawing",
              "props": {
                "duration": 3,
                "mode": "oneByOne",
                "strokeColor": "{{strokeColor}}",
                "strokeWidth": 4,
                "delay": 0.2,
                "easing": "ease-in-out",
                "viewBox": "0 0 200 200",
                "svgContent": "<svg viewBox=\"0 0 200 200\"><path d=\"M100,20 L120,80 L180,80 L135,115 L155,175 L100,140 L45,175 L65,115 L20,80 L80,80 Z\" /><circle cx=\"100\" cy=\"100\" r=\"85\" /></svg>"
              }
            }
          },
          {
            "id": "title",
            "type": "text",
            "position": {
              "x": 460,
              "y": 880
            },
            "size": {
              "width": 1000,
              "height": 100
            },
            "props": {
              "text": "{{title}}",
              "fontSize": 68,
              "fontWeight": "bold",
              "color": "#ffffff",
              "textAlign": "center",
              "letterSpacing": 10
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInUp",
                "delay": 80,
                "duration": 20
              }
            ]
          },
          {
            "id": "subtitle",
            "type": "text",
            "position": {
              "x": 660,
              "y": 970
            },
            "size": {
              "width": 600,
              "height": 50
            },
            "props": {
              "text": "Animated Logo Reveal",
              "fontSize": 24,
              "color": "{{strokeColor}}",
              "textAlign": "center",
              "letterSpacing": 2
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 95,
                "duration": 15
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": {
              "x": 1520,
              "y": 20
            },
            "size": {
              "width": 380,
              "height": 60
            },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7,
              "textShadow": "0 2px 4px rgba(0,0,0,0.5)"
            },
            "animations": []
          }
        ]
      }
    ]
  }
}