{
  "name": "Typewriter Story",
  "description": "Elegant story or quote display with gradient background and typewriter effect.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 8
  },
  "inputs": [
    {
      "key": "quote",
      "type": "string",
      "label": "Quote Text",
      "required": true,
      "default": "The only way to do great work is to love what you do."
    },
    {
      "key": "author",
      "type": "string",
      "label": "Author Name",
      "required": true,
      "default": "Steve Jobs"
    },
    {
      "key": "accentColor",
      "type": "color",
      "label": "Accent Color",
      "required": false,
      "default": "#8b5cf6"
    }
  ],
  "defaults": {
    "quote": "The only way to do great work is to love what you do.",
    "author": "Steve Jobs",
    "accentColor": "#8b5cf6"
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 240,
        "layers": [
          {
            "id": "background-gradient-1",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "shape": "rectangle",
              "fill": "#1e1b4b"
            },
            "animations": []
          },
          {
            "id": "aurora-blob-1",
            "type": "shape",
            "position": {
              "x": 300,
              "y": 200
            },
            "size": {
              "width": 600,
              "height": 600
            },
            "opacity": 0.3,
            "props": {
              "shape": "ellipse",
              "fill": "#8b5cf6"
            },
            "animations": []
          },
          {
            "id": "aurora-blob-2",
            "type": "shape",
            "position": {
              "x": 1100,
              "y": 300
            },
            "size": {
              "width": 500,
              "height": 500
            },
            "opacity": 0.2,
            "props": {
              "shape": "ellipse",
              "fill": "#ec4899"
            },
            "animations": []
          },
          {
            "id": "aurora-blob-3",
            "type": "shape",
            "position": {
              "x": 700,
              "y": 500
            },
            "size": {
              "width": 550,
              "height": 550
            },
            "opacity": 0.25,
            "props": {
              "shape": "ellipse",
              "fill": "#06b6d4"
            },
            "animations": []
          },
          {
            "id": "quote-mark-open",
            "type": "text",
            "position": {
              "x": 260,
              "y": 350
            },
            "size": {
              "width": 100,
              "height": 100
            },
            "opacity": 0.4,
            "props": {
              "text": "\"",
              "fontSize": 120,
              "fontWeight": "bold",
              "color": "{{accentColor}}",
              "fontFamily": "serif",
              "textAlign": "left"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 20,
                "duration": 25
              }
            ]
          },
          {
            "id": "quote-text",
            "type": "custom",
            "position": {
              "x": 360,
              "y": 420
            },
            "size": {
              "width": 1200,
              "height": 200
            },
            "customComponent": {
              "name": "TypewriterEffect",
              "props": {
                "text": "{{quote}}",
                "fontSize": 48,
                "fontWeight": "500",
                "color": "#ffffff",
                "fontFamily": "serif",
                "textAlign": "center",
                "speed": "normal",
                "cursor": true,
                "cursorStyle": "bar",
                "cursorColor": "{{accentColor}}",
                "startDelay": 50,
                "lineHeight": 1.6
              }
            },
            "animations": []
          },
          {
            "id": "quote-mark-close",
            "type": "text",
            "position": {
              "x": 1560,
              "y": 500
            },
            "size": {
              "width": 100,
              "height": 100
            },
            "opacity": 0.4,
            "props": {
              "text": "\"",
              "fontSize": 120,
              "fontWeight": "bold",
              "color": "{{accentColor}}",
              "fontFamily": "serif",
              "textAlign": "right"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 155,
                "duration": 25
              }
            ]
          },
          {
            "id": "divider",
            "type": "shape",
            "position": {
              "x": 810,
              "y": 640
            },
            "size": {
              "width": 300,
              "height": 3
            },
            "props": {
              "shape": "rectangle",
              "fill": "{{accentColor}}"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 165,
                "duration": 20
              }
            ]
          },
          {
            "id": "author",
            "type": "text",
            "position": {
              "x": 560,
              "y": 670
            },
            "size": {
              "width": 800,
              "height": 60
            },
            "props": {
              "text": "\u2014 {{author}}",
              "fontSize": 32,
              "fontWeight": "300",
              "color": "#e2e8f0",
              "fontFamily": "serif",
              "textAlign": "center",
              "letterSpacing": 2
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 185,
                "duration": 30
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": {
              "x": 1520,
              "y": 20
            },
            "size": {
              "width": 380,
              "height": 60
            },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7,
              "textShadow": "0 2px 4px rgba(0,0,0,0.5)"
            },
            "animations": []
          }
        ]
      }
    ]
  }
}