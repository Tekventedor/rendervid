{
  "name": "Event Countdown Timer",
  "description": "Animated event countdown with flip-style time display, decorative star particles, gradient background, and event details. Uses a custom component for the countdown cards.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 8
  },
  "inputs": [
    { "key": "eventName", "type": "string", "label": "Event Name", "required": true, "default": "INNOVATION SUMMIT" },
    { "key": "eventDate", "type": "string", "label": "Event Date", "required": true, "default": "MARCH 15, 2026" },
    { "key": "venue", "type": "string", "label": "Venue", "required": true, "default": "Moscone Center, San Francisco" },
    { "key": "website", "type": "string", "label": "Website", "required": false, "default": "innovationsummit.io" },
    { "key": "accentColor", "type": "color", "label": "Accent Color", "required": false, "default": "#a855f7" }
  ],
  "defaults": {
    "eventName": "INNOVATION SUMMIT",
    "eventDate": "MARCH 15, 2026",
    "venue": "Moscone Center, San Francisco",
    "website": "innovationsummit.io",
    "accentColor": "#a855f7"
  },
  "customComponents": {
    "CountdownDisplay": {
      "type": "inline",
      "code": "function CountdownDisplay(props) { var frame = props.frame; var fps = props.fps; var accent = props.accentColor || '#a855f7'; var totalSec = 33 * 24 * 3600 + 14 * 3600 + 27 * 60 + 53; var elapsed = frame / fps; var remaining = Math.max(0, totalSec - Math.floor(elapsed)); var days = Math.floor(remaining / 86400); var hours = Math.floor((remaining % 86400) / 3600); var mins = Math.floor((remaining % 3600) / 60); var secs = remaining % 60; var units = [{label: 'DAYS', value: days}, {label: 'HOURS', value: hours}, {label: 'MINUTES', value: mins}, {label: 'SECONDS', value: secs}]; var flipPhase = (frame % fps) / fps; var containerStyle = { display: 'flex', justifyContent: 'center', alignItems: 'center', gap: '24px', width: '100%', height: '100%' }; var cards = units.map(function(u, i) { var delay = i * 8; var progress = Math.min(Math.max((frame - delay) / 20, 0), 1); var ease = 1 - Math.pow(1 - progress, 3); var cardStyle = { display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '12px', opacity: ease, transform: 'translateY(' + ((1 - ease) * 40) + 'px)' }; var numBoxStyle = { width: '180px', height: '160px', background: 'linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%)', borderRadius: '16px', display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', border: '1px solid rgba(255,255,255,0.1)', position: 'relative', overflow: 'hidden', boxShadow: '0 8px 32px rgba(0,0,0,0.3)' }; var midLine = React.createElement('div', { style: { position: 'absolute', top: '50%', left: 0, right: 0, height: '1px', background: 'rgba(0,0,0,0.3)' }}); var numStyle = { fontSize: '72px', fontWeight: '200', color: '#ffffff', fontFamily: 'Inter, system-ui, sans-serif', letterSpacing: '-2px', lineHeight: '1', zIndex: 1 }; var labelStyle = { fontSize: '12px', fontWeight: '500', color: accent, letterSpacing: '4px', fontFamily: 'Inter, system-ui, sans-serif' }; var val = u.value < 10 ? '0' + u.value : '' + u.value; return React.createElement('div', { key: i, style: cardStyle }, React.createElement('div', { style: numBoxStyle }, midLine, React.createElement('span', { style: numStyle }, val)), React.createElement('span', { style: labelStyle }, u.label)); }); return React.createElement('div', { style: containerStyle }, cards); }",
      "description": "Flip-style countdown timer with 4 time unit cards"
    }
  },
