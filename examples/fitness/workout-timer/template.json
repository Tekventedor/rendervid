{
  "name": "Workout Timer",
  "description": "Exercise interval timer with workout name and countdown.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "duration": 8
  },
  "inputs": [
    {
      "key": "roundLabel",
      "type": "string",
      "label": "Round Label",
      "required": false,
      "default": "ROUND 3 OF 5"
    },
    {
      "key": "exerciseName",
      "type": "string",
      "label": "Exercise Name",
      "required": true,
      "default": "BURPEES"
    },
    {
      "key": "timerDisplay",
      "type": "string",
      "label": "Timer Display",
      "required": true,
      "default": "0:45"
    },
    {
      "key": "nextExercise",
      "type": "string",
      "label": "Next Exercise",
      "required": false,
      "default": "Mountain Climbers"
    }
  ],
  "defaults": {
    "roundLabel": "ROUND 3 OF 5",
    "exerciseName": "BURPEES",
    "timerDisplay": "0:45",
    "nextExercise": "Mountain Climbers"
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 240,
        "layers": [
          {
            "id": "bg",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1080,
              "height": 1920
            },
            "props": {
              "shape": "rectangle",
              "fill": "#0f172a"
            }
          },
          {
            "id": "accent",
            "type": "shape",
            "position": {
              "x": 290,
              "y": 750
            },
            "size": {
              "width": 500,
              "height": 500
            },
            "opacity": 0.2,
            "props": {
              "shape": "rectangle",
              "fill": "#22c55e"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 20,
                "duration": 30
              }
            ]
          },
          {
            "id": "round",
            "type": "text",
            "position": {
              "x": 140,
              "y": 400
            },
            "size": {
              "width": 800,
              "height": 50
            },
            "props": {
              "text": "{{roundLabel}}",
              "fontSize": 36,
              "fontWeight": "600",
              "color": "#22c55e",
              "textAlign": "center"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 10,
                "duration": 20
              }
            ]
          },
          {
            "id": "exercise",
            "type": "text",
            "position": {
              "x": 90,
              "y": 520
            },
            "size": {
              "width": 900,
              "height": 120
            },
            "props": {
              "text": "{{exerciseName}}",
              "fontSize": 72,
              "fontWeight": "bold",
              "color": "#ffffff",
              "textAlign": "center"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 25,
                "duration": 25
              }
            ]
          },
          {
            "id": "timer",
            "type": "text",
            "position": {
              "x": 290,
              "y": 900
            },
            "size": {
              "width": 500,
              "height": 180
            },
            "props": {
              "text": "{{timerDisplay}}",
              "fontSize": 140,
              "fontWeight": "bold",
              "color": "#22c55e",
              "textAlign": "center"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 40,
                "duration": 25
              }
            ]
          },
          {
            "id": "next-label",
            "type": "text",
            "position": {
              "x": 340,
              "y": 1150
            },
            "size": {
              "width": 400,
              "height": 40
            },
            "props": {
              "text": "NEXT UP",
              "fontSize": 24,
              "color": "#6b7280",
              "textAlign": "center"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 55,
                "duration": 20
              }
            ]
          },
          {
            "id": "next",
            "type": "text",
            "position": {
              "x": 140,
              "y": 1220
            },
            "size": {
              "width": 800,
              "height": 50
            },
            "props": {
              "text": "{{nextExercise}}",
              "fontSize": 36,
              "color": "#94a3b8",
              "textAlign": "center"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInUp",
                "delay": 60,
                "duration": 25
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": {
              "x": 1520,
              "y": 20
            },
            "size": {
              "width": 380,
              "height": 60
            },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7,
              "textShadow": "0 2px 4px rgba(0,0,0,0.5)"
            }
          }
        ]
      }
    ]
  }
}
