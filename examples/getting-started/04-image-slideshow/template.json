{
  "name": "Image Slideshow",
  "description": "Create a beautiful slideshow with smooth fade transitions between images.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 12
  },
  "inputs": [
    {
      "key": "image1",
      "type": "url",
      "label": "First Image",
      "description": "URL to the first image",
      "required": true,
      "default": "https://www.photomaticai.com/images/processed/ai-generated-images/models_flux-dev_ai-image-generator_soft-retro_1970s_Soft_Retro_Living_Room.webp",
      "validation": {
        "allowedTypes": [
          "image"
        ]
      }
    },
    {
      "key": "image2",
      "type": "url",
      "label": "Second Image",
      "description": "URL to the second image",
      "required": true,
      "default": "https://www.photomaticai.com/images/processed/ai-generated-images/models_ideogram-v3-balanced_ai-image-generator_pen_Whimsical_Pencil_Cityscape.webp",
      "validation": {
        "allowedTypes": [
          "image"
        ]
      }
    },
    {
      "key": "image3",
      "type": "url",
      "label": "Third Image",
      "description": "URL to the third image",
      "required": true,
      "default": "https://www.photomaticai.com/images/processed/styles/foqzv_Abstract_Portrait_for_a_Modern_Art_Gallery.webp",
      "validation": {
        "allowedTypes": [
          "image"
        ]
      }
    }
  ],
  "defaults": {
    "image1": "https://www.photomaticai.com/images/processed/ai-generated-images/models_flux-dev_ai-image-generator_soft-retro_1970s_Soft_Retro_Living_Room.webp",
    "image2": "https://www.photomaticai.com/images/processed/ai-generated-images/models_ideogram-v3-balanced_ai-image-generator_pen_Whimsical_Pencil_Cityscape.webp",
    "image3": "https://www.photomaticai.com/images/processed/styles/foqzv_Abstract_Portrait_for_a_Modern_Art_Gallery.webp"
  },
  "composition": {
    "scenes": [
      {
        "id": "slide-1",
        "startFrame": 0,
        "endFrame": 120,
        "layers": [
          {
            "id": "bg",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "shape": "rectangle",
              "fill": "#000000"
            }
          },
          {
            "id": "image-1",
            "type": "image",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "src": "{{image1}}",
              "fit": "cover"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 0,
                "duration": 30
              },
              {
                "type": "keyframe",
                "duration": 120,
                "keyframes": [
                  {
                    "frame": 0,
                    "properties": {
                      "scaleX": 1,
                      "scaleY": 1
                    }
                  },
                  {
                    "frame": 120,
                    "properties": {
                      "scaleX": 1.1,
                      "scaleY": 1.1
                    }
                  }
                ]
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": {
              "x": 1520,
              "y": 20
            },
            "size": {
              "width": 380,
              "height": 60
            },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7,
              "textShadow": "0 2px 4px rgba(0,0,0,0.5)"
            }
          }
        ]
      },
      {
        "id": "slide-2",
        "startFrame": 120,
        "endFrame": 240,
        "transition": {
          "type": "fade",
          "duration": 30
        },
        "layers": [
          {
            "id": "bg",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "shape": "rectangle",
              "fill": "#000000"
            }
          },
          {
            "id": "image-2",
            "type": "image",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "src": "{{image2}}",
              "fit": "cover"
            },
            "animations": [
              {
                "type": "keyframe",
                "duration": 120,
                "keyframes": [
                  {
                    "frame": 0,
                    "properties": {
                      "scaleX": 1,
                      "scaleY": 1
                    }
                  },
                  {
                    "frame": 120,
                    "properties": {
                      "scaleX": 1.1,
                      "scaleY": 1.1
                    }
                  }
                ]
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": {
              "x": 1520,
              "y": 20
            },
            "size": {
              "width": 380,
              "height": 60
            },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7,
              "textShadow": "0 2px 4px rgba(0,0,0,0.5)"
            }
          }
        ]
      },
      {
        "id": "slide-3",
        "startFrame": 240,
        "endFrame": 360,
        "transition": {
          "type": "fade",
          "duration": 30
        },
        "layers": [
          {
            "id": "bg",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "shape": "rectangle",
              "fill": "#000000"
            }
          },
          {
            "id": "image-3",
            "type": "image",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "src": "{{image3}}",
              "fit": "cover"
            },
            "animations": [
              {
                "type": "keyframe",
                "duration": 120,
                "keyframes": [
                  {
                    "frame": 0,
                    "properties": {
                      "scaleX": 1,
                      "scaleY": 1
                    }
                  },
                  {
                    "frame": 120,
                    "properties": {
                      "scaleX": 1.1,
                      "scaleY": 1.1
                    }
                  }
                ]
              },
              {
                "type": "exit",
                "effect": "fadeOut",
                "delay": 90,
                "duration": 30
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": {
              "x": 1520,
              "y": 20
            },
            "size": {
              "width": 380,
              "height": 60
            },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7,
              "textShadow": "0 2px 4px rgba(0,0,0,0.5)"
            }
          }
        ]
      }
    ]
  }
}
