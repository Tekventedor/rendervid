{
  "name": "Motion Blur - Basic Example",
  "description": "Simple example showing motion blur effect on moving shapes",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 3
  },
  "inputs": [],
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 90,
        "backgroundColor": "#1a1a2e",
        "layers": [
          {
            "id": "title",
            "type": "text",
            "position": { "x": 260, "y": 120 },
            "size": { "width": 1400, "height": 100 },
            "props": {
              "text": "Motion Blur Demonstration",
              "fontSize": 56,
              "fontWeight": "bold",
              "textAlign": "center",
              "color": "#ffffff"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 0,
                "duration": 20
              }
            ]
          },
          {
            "id": "fast-box",
            "type": "shape",
            "position": { "x": -100, "y": 400 },
            "size": { "width": 100, "height": 100 },
            "props": {
              "type": "rectangle",
              "color": "#ff6b6b",
              "borderRadius": 10
            },
            "animations": [
              {
                "type": "custom",
                "keyframes": [
                  {
                    "frame": 30,
                    "properties": {
                      "position": { "x": -100, "y": 400 }
                    }
                  },
                  {
                    "frame": 60,
                    "properties": {
                      "position": { "x": 1920, "y": 400 }
                    }
                  }
                ],
                "easing": "linear"
              }
            ]
          },
          {
            "id": "rotating-square",
            "type": "shape",
            "position": { "x": 260, "y": 700 },
            "size": { "width": 150, "height": 150 },
            "rotation": 0,
            "props": {
              "type": "rectangle",
              "color": "#4ecdc4",
              "borderRadius": 5
            },
            "animations": [
              {
                "type": "custom",
                "keyframes": [
                  {
                    "frame": 30,
                    "properties": {
                      "rotation": 0
                    }
                  },
                  {
                    "frame": 60,
                    "properties": {
                      "rotation": 360
                    }
                  }
                ],
                "easing": "linear"
              }
            ]
          },
          {
            "id": "instructions",
            "type": "text",
            "position": { "x": 260, "y": 920 },
            "size": { "width": 1400, "height": 100 },
            "props": {
              "text": "Enable motion blur to see smooth, natural motion instead of strobing",
              "fontSize": 28,
              "textAlign": "center",
              "color": "#aaaaaa"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 20,
                "duration": 20
              }
            ]
          }
        ]
      }
    ]
  }
}
