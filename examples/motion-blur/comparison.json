{
  "name": "Motion Blur - Speed Comparison",
  "description": "Side-by-side: slow box (7 px/frame, subtle blur) vs fast box (53 px/frame, heavy blur) — both with motion blur enabled",
  "version": "2.0.0",
  "output": {"type": "video", "width": 1920, "height": 1080, "fps": 30, "duration": 4},
  "customComponents": {
    "ComparisonDemo": {
      "type": "inline",
      "description": "Left: slow red box ping-pongs at 7px/frame. Right: fast teal box ping-pongs at 53px/frame. Divider line at center. Same motion blur applied to both — slow stays sharp, fast streaks.",
      "code": "function(props){var f=props.frame,W=props.layerSize.width,H=props.layerSize.height;function tri(n,p){var t=((n%p)+p)%p/p;return t<0.5?t*2:(1-t)*2;}var slowX=80+800*tri(f,240),fastX=1040+800*tri(f,30);return React.createElement('svg',{xmlns:'http://www.w3.org/2000/svg',width:W,height:H,style:{position:'absolute',top:0,left:0,overflow:'hidden'}},React.createElement('rect',{x:955,y:200,width:10,height:780,fill:'#333344'}),React.createElement('rect',{x:slowX,y:500,width:80,height:80,fill:'#ff6b6b',rx:8}),React.createElement('rect',{x:fastX,y:500,width:80,height:80,fill:'#4ecdc4',rx:8}));}"
    }
  },
