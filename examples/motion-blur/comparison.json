{
  "name": "Motion Blur - Side-by-Side Comparison",
  "description": "Compare no blur vs motion blur side by side",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 4
  },
  "inputs": [],
  "composition": {
    "scenes": [
      {
        "id": "comparison",
        "startFrame": 0,
        "endFrame": 120,
        "backgroundColor": "#0f0f1e",
        "motionBlur": {
          "enabled": false
        },
        "layers": [
          {
            "id": "title",
            "type": "text",
            "position": { "x": 260, "y": 120 },
            "size": { "width": 1400, "height": 100 },
            "props": {
              "text": "Motion Blur Comparison",
              "fontSize": 52,
              "fontWeight": "bold",
              "textAlign": "center",
              "color": "#ffffff"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 0,
                "duration": 15
              }
            ]
          },
          {
            "id": "left-label",
            "type": "text",
            "position": { "x": 130, "y": 270 },
            "size": { "width": 700, "height": 80 },
            "props": {
              "text": "Without Motion Blur",
              "fontSize": 32,
              "textAlign": "center",
              "color": "#ff6b6b"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 15,
                "duration": 15
              }
            ]
          },
          {
            "id": "right-label",
            "type": "text",
            "position": { "x": 1090, "y": 270 },
            "size": { "width": 700, "height": 80 },
            "props": {
              "text": "With Motion Blur",
              "fontSize": 32,
              "textAlign": "center",
              "color": "#4ecdc4"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 15,
                "duration": 15
              }
            ]
          },
          {
            "id": "divider",
            "type": "shape",
            "position": { "x": 955, "y": 200 },
            "size": { "width": 10, "height": 800 },
            "props": {
              "type": "rectangle",
              "color": "#333344"
            }
          },
          {
            "id": "left-box",
            "type": "shape",
            "position": { "x": 180, "y": 500 },
            "size": { "width": 80, "height": 80 },
            "props": {
              "type": "rectangle",
              "color": "#ff6b6b",
              "borderRadius": 8
            },
            "motionBlur": {
              "enabled": false
            },
            "animations": [
              {
                "type": "custom",
                "keyframes": [
                  {
                    "frame": 30,
                    "properties": {
                      "position": { "x": 180, "y": 500 }
                    }
                  },
                  {
                    "frame": 90,
                    "properties": {
                      "position": { "x": 780, "y": 500 }
                    }
                  }
                ],
                "easing": "easeInOutCubic"
              }
            ]
          },
          {
            "id": "right-box",
            "type": "shape",
            "position": { "x": 1140, "y": 500 },
            "size": { "width": 80, "height": 80 },
            "props": {
              "type": "rectangle",
              "color": "#4ecdc4",
              "borderRadius": 8
            },
            "motionBlur": {
              "enabled": true,
              "quality": "high"
            },
            "animations": [
              {
                "type": "custom",
                "keyframes": [
                  {
                    "frame": 30,
                    "properties": {
                      "position": { "x": 1140, "y": 500 }
                    }
                  },
                  {
                    "frame": 90,
                    "properties": {
                      "position": { "x": 1740, "y": 500 }
                    }
                  }
                ],
                "easing": "easeInOutCubic"
              }
            ]
          },
          {
            "id": "description",
            "type": "text",
            "position": { "x": 260, "y": 920 },
            "size": { "width": 1400, "height": 100 },
            "props": {
              "text": "Notice the smooth, natural blur on the right vs. sharp strobing on the left",
              "fontSize": 26,
              "textAlign": "center",
              "color": "#aaaaaa"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 30,
                "duration": 20
              }
            ]
          }
        ]
      }
    ]
  }
}
