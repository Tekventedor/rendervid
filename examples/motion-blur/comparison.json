          "position": {"x": 260, "y": 60},
          "size": {"width": 1400, "height": 100},
          "props": {
            "text": "Motion Blur — Speed Comparison",
            "fontSize": 52,
            "fontWeight": "bold",
            "textAlign": "center",
            "color": "#ffffff"
          },
          "animations": [{"type": "entrance", "effect": "fadeIn", "delay": 0, "duration": 121}]
        },
        {
          "id": "left-label",
          "type": "text",
          "position": {"x": 130, "y": 250},
          "size": {"width": 700, "height": 80},
          "props": {
