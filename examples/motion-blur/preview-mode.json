{
  "name": "Motion Blur - Preview Mode",
  "description": "Fast preview mode with 3 objects: box sweeps left-to-right, square rotates, box sweeps right-to-left",
  "version": "2.0.0",
  "output": {"type": "video", "width": 1920, "height": 1080, "fps": 30, "duration": 3},
  "customComponents": {
    "PreviewModeDemo": {
      "type": "inline",
      "description": "Three moving objects: red box sweeps L→R at 24.7px/f, teal square rotates 8deg/f, yellow box sweeps R→L at 24.7px/f. Fractional frame support enables preview-mode temporal supersampling.",
      "code": "function(props){var f=props.frame,W=props.layerSize.width,H=props.layerSize.height,x1=-100+f*(2220/90),x3=2120-f*(2220/90),rot=f*8,cx=910,cy=540,sz=150;return React.createElement('svg',{xmlns:'http://www.w3.org/2000/svg',width:W,height:H,style:{position:'absolute',top:0,left:0,overflow:'hidden'}},React.createElement('rect',{x:x1,y:350,width:100,height:100,fill:'#ff6b6b',rx:10}),React.createElement('rect',{x:cx-sz/2,y:cy-sz/2,width:sz,height:sz,fill:'#4ecdc4',rx:5,transform:'rotate('+rot+','+cx+','+cy+')'}),React.createElement('rect',{x:x3,y:730,width:100,height:100,fill:'#f7b731',rx:10}));}"
    }
  },
  "composition": {
    "scenes": [{
      "id": "preview-demo",
      "startFrame": 0,
      "endFrame": 90,
      "layers": [
        {
          "id": "bg",
          "type": "shape",
          "position": {"x": 0, "y": 0},
          "size": {"width": 1920, "height": 1080},
          "props": {"shape": "rectangle", "fill": "#1a1a2e"}
        },
        {
          "id": "anim",
          "type": "custom",
          "position": {"x": 0, "y": 0},
          "size": {"width": 1920, "height": 1080},
          "customComponent": {"name": "PreviewModeDemo", "props": {}}
        },
        {
          "id": "title",
          "type": "text",
          "position": {"x": 260, "y": 120},
          "size": {"width": 1400, "height": 100},
          "props": {
            "text": "Preview Mode — Fast Iteration",
            "fontSize": 52,
            "fontWeight": "bold",
            "textAlign": "center",
            "color": "#ffffff"
          }
        },
        {
          "id": "description",
          "type": "text",
          "position": {"x": 260, "y": 940},
          "size": {"width": 1400, "height": 120},
          "props": {
            "text": "Preview mode uses 2 samples for ~2× render time (vs 10× for normal)\nPerfect for layout and timing preview during development",
            "fontSize": 26,
            "textAlign": "center",
            "color": "#aaaaaa"
          }
        }
      ]
    }]
  }
}
