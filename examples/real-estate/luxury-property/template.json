    { "key": "agentName", "type": "string", "label": "Agent Name", "required": true, "default": "Victoria Sterling" },
    { "key": "agentPhone", "type": "string", "label": "Agent Phone", "required": true, "default": "+1 (310) 555-0182" },
    { "key": "propertyImage", "type": "url", "label": "Property Image", "required": false, "default": "property.jpg" }
