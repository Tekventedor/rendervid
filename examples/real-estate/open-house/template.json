{
  "name": "Open House",
  "description": "Open house announcement with date, time, and address.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 6
  },
  "inputs": [
    {
      "key": "eventDate",
      "type": "string",
      "label": "Event Date",
      "required": true,
      "default": "Saturday, March 15"
    },
    {
      "key": "eventTime",
      "type": "string",
      "label": "Event Time",
      "required": true,
      "default": "1:00 PM - 4:00 PM"
    },
    {
      "key": "address",
      "type": "string",
      "label": "Address",
      "required": true,
      "default": "456 Maple Avenue, Santa Monica, CA"
    }
  ],
  "defaults": {
    "eventDate": "Saturday, March 15",
    "eventTime": "1:00 PM - 4:00 PM",
    "address": "456 Maple Avenue, Santa Monica, CA"
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 180,
        "layers": [
          {
            "id": "bg",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 1080
            },
            "props": {
              "shape": "rectangle",
              "fill": "#1e3a5f"
            }
          },
          {
            "id": "featured-image",
            "type": "image",
            "position": {
              "x": 0,
              "y": 0
            },
            "size": {
              "width": 1920,
              "height": 650
            },
            "props": {
              "src": "house.jpg",
              "fit": "cover"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 5,
                "duration": 25
              }
            ]
          },
          {
            "id": "banner-bg",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 350
            },
            "size": {
              "width": 1920,
              "height": 380
            },
            "opacity": 0.95,
            "props": {
              "shape": "rectangle",
              "fill": "#ffffff"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInLeft",
                "delay": 0,
                "duration": 25
              }
            ]
          },
          {
            "id": "accent",
            "type": "shape",
            "position": {
              "x": 0,
              "y": 350
            },
            "size": {
              "width": 20,
              "height": 380
            },
            "props": {
              "shape": "rectangle",
              "fill": "#16a34a"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInLeft",
                "delay": 0,
                "duration": 20
              }
            ]
          },
          {
            "id": "label",
            "type": "text",
            "position": {
              "x": 100,
              "y": 390
            },
            "size": {
              "width": 400,
              "height": 50
            },
            "props": {
              "text": "OPEN HOUSE",
              "fontSize": 28,
              "fontWeight": "bold",
              "color": "#16a34a",
              "textAlign": "left"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 25,
                "duration": 20
              }
            ]
          },
          {
            "id": "date",
            "type": "text",
            "position": {
              "x": 100,
              "y": 480
            },
            "size": {
              "width": 1000,
              "height": 80
            },
            "props": {
              "text": "{{eventDate}}",
              "fontSize": 56,
              "fontWeight": "bold",
              "color": "#1f2937",
              "textAlign": "left"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInLeft",
                "delay": 35,
                "duration": 25
              }
            ]
          },
          {
            "id": "time",
            "type": "text",
            "position": {
              "x": 100,
              "y": 570
            },
            "size": {
              "width": 800,
              "height": 50
            },
            "props": {
              "text": "{{eventTime}}",
              "fontSize": 36,
              "color": "#6b7280",
              "textAlign": "left"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 45,
                "duration": 20
              }
            ]
          },
          {
            "id": "address",
            "type": "text",
            "position": {
              "x": 100,
              "y": 650
            },
            "size": {
              "width": 1200,
              "height": 50
            },
            "props": {
              "text": "{{address}}",
              "fontSize": 28,
              "fontWeight": "600",
              "color": "#3b82f6",
              "textAlign": "left"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "slideInUp",
                "delay": 55,
                "duration": 20
              }
            ]
          }
        ]
      }
    ]
  }
}