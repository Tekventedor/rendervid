            "animations": [
              {
                "type": "entrance",
                "effect": "slideInUp",
                "delay": 60,
                "duration": 20
              }
            ]
          },
          {
            "id": "address",
            "type": "text",
            "position": {
              "x": 560,
              "y": 760
            },
            "size": {
              "width": 800,
              "height": 40
