    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 6
  },
  "inputs": [
    {
      "key": "oldPrice",
      "type": "string",
      "label": "Old Price",
      "required": true,
      "default": "Was $950,000"
    },
    {
      "key": "newPrice",
      "type": "string",
      "label": "New Price",
      "required": true,
      "default": "$875,000"
    },
    {
      "key": "savings",
      "type": "string",
      "label": "Savings",
      "required": false,
      "default": "SAVE $75,000"
    },
    {
      "key": "address",
      "type": "string",
      "label": "Address",
      "required": false,
      "default": "1234 Oak Street, Beverly Hills, CA"
    }
  ],
  "defaults": {
    "oldPrice": "Was $950,000",
    "newPrice": "$875,000",
    "savings": "SAVE $75,000",
    "address": "1234 Oak Street, Beverly Hills, CA"
