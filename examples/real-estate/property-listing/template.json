{
  "name": "Property Listing",
  "description": "Real estate property showcase with key details and price.",
  "version": "1.0.0",
  "output": { "type": "video", "width": 1920, "height": 1080, "fps": 30, "duration": 8 },
  "inputs": [
    { "key": "listingType", "type": "string", "label": "Listing Type", "required": false, "default": "FOR SALE" },
    { "key": "price", "type": "string", "label": "Price", "required": true, "default": "$875,000" },
    { "key": "address", "type": "string", "label": "Address", "required": true, "default": "1234 Oak Street, Beverly Hills, CA" },
    { "key": "details", "type": "string", "label": "Details", "required": false, "default": "4 Beds • 3 Baths • 2,850 sqft" }
  ],
  "defaults": { "listingType": "FOR SALE", "price": "$875,000", "address": "1234 Oak Street, Beverly Hills, CA", "details": "4 Beds • 3 Baths • 2,850 sqft" },
  "composition": { "scenes": [{ "id": "main", "startFrame": 0, "endFrame": 240, "layers": [
    { "id": "bg", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#1f2937" } },
    { "id": "badge-bg", "type": "shape", "position": { "x": 80, "y": 80 }, "size": { "width": 200, "height": 60 }, "props": { "shape": "rectangle", "fill": "#dc2626" }, "animations": [{ "type": "entrance", "effect": "scaleIn", "delay": 0, "duration": 20 }] },
    { "id": "badge", "type": "text", "position": { "x": 80, "y": 95 }, "size": { "width": 200, "height": 40 }, "props": { "text": "{{listingType}}", "fontSize": 24, "fontWeight": "bold", "color": "#ffffff", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 15, "duration": 20 }] },
    { "id": "info-bg", "type": "shape", "position": { "x": 0, "y": 700 }, "size": { "width": 1920, "height": 380 }, "opacity": 0.95, "props": { "shape": "rectangle", "fill": "#ffffff" }, "animations": [{ "type": "entrance", "effect": "slideInUp", "delay": 25, "duration": 25 }] },
    { "id": "price", "type": "text", "position": { "x": 100, "y": 740 }, "size": { "width": 600, "height": 80 }, "props": { "text": "{{price}}", "fontSize": 56, "fontWeight": "bold", "color": "#16a34a", "textAlign": "left" }, "animations": [{ "type": "entrance", "effect": "slideInLeft", "delay": 40, "duration": 25 }] },
    { "id": "address", "type": "text", "position": { "x": 100, "y": 840 }, "size": { "width": 1000, "height": 50 }, "props": { "text": "{{address}}", "fontSize": 32, "fontWeight": "600", "color": "#1f2937", "textAlign": "left" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 50, "duration": 20 }] },
    { "id": "details", "type": "text", "position": { "x": 100, "y": 910 }, "size": { "width": 800, "height": 40 }, "props": { "text": "{{details}}", "fontSize": 24, "color": "#6b7280", "textAlign": "left" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 60, "duration": 20 }] }
  ]}]}
}
