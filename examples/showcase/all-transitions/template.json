            "id": "desc",
            "type": "text",
            "position": { "x": 160, "y": 580 },
            "size": { "width": 1600, "height": 60 },
            "props": {
              "text": "Instant switch between scenes (no transition)",
              "fontSize": 32,
              "color": "#ddd6fe",
              "textAlign": "center"
