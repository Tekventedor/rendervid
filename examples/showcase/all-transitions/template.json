{
  "name": "All Scene Transitions Showcase",
  "description": "Demonstrates all scene transition types: cut, fade, slide, wipe, and zoom.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 18
  },
  "composition": {
    "scenes": [
      {
        "id": "intro",
        "startFrame": 0,
        "endFrame": 90,
        "transition": {
          "type": "cut",
          "duration": 0
        },
        "layers": [
          {
            "id": "bg",
            "type": "shape",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 1920, "height": 1080 },
            "props": {
              "shape": "rectangle",
              "fill": "#3b82f6"
            }
          },
          {
            "id": "title",
            "type": "text",
            "position": { "x": 160, "y": 440 },
            "size": { "width": 1600, "height": 120 },
            "props": {
              "text": "Scene Transitions",
              "fontSize": 96,
              "fontWeight": "bold",
              "color": "#ffffff",
              "textAlign": "center"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "scaleIn",
                "delay": 0,
                "duration": 20
              }
            ]
          },
          {
            "id": "subtitle",
            "type": "text",
            "position": { "x": 160, "y": 580 },
            "size": { "width": 1600, "height": 60 },
            "props": {
              "text": "Watch how scenes change with different transitions",
              "fontSize": 32,
              "color": "#bfdbfe",
              "textAlign": "center"
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeIn",
                "delay": 15,
                "duration": 20
              }
            ]
          },
          {
            "id": "watermark",
            "type": "text",
            "position": { "x": 1520, "y": 20 },
            "size": { "width": 380, "height": 60 },
            "props": {
              "text": "RenderVid by\nFlowHunt.io",
              "fontSize": 16,
              "fontWeight": "600",
              "color": "#ffffff",
              "textAlign": "right",
              "lineHeight": 1.3,
              "opacity": 0.7
            }
          }
        ]
      },
      {
        "id": "cut",
        "startFrame": 90,
        "endFrame": 180,
        "transition": {
          "type": "fade",
          "duration": 30
