{
  "name": "All Scene Transitions Showcase",
  "description": "Demonstrates scene transition concepts (Note: Transitions are manually animated since scene transition system is not yet implemented).",
  "version": "1.0.0",
  "output": { "type": "video", "width": 1920, "height": 1080, "fps": 30, "duration": 15 },
  "inputs": [],
  "defaults": {},
  "composition": {
    "scenes": [
      {
        "id": "intro", "startFrame": 0, "endFrame": 60,
        "layers": [
          { "id": "bg", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#3b82f6" } },
          { "id": "title", "type": "text", "position": { "x": 160, "y": 440 }, "size": { "width": 1600, "height": 120 }, "props": { "text": "Scene Transitions", "fontSize": 96, "fontWeight": "bold", "color": "#ffffff", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "scaleIn", "delay": 0, "duration": 20 }] },
          { "id": "subtitle", "type": "text", "position": { "x": 160, "y": 580 }, "size": { "width": 1600, "height": 60 }, "props": { "text": "Smooth transitions between scenes", "fontSize": 32, "color": "#bfdbfe", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 15, "duration": 20 }] },
          { "id": "fadeout", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#000000" }, "opacity": 0, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 45, "duration": 15 }] }
        ]
      },
      {
        "id": "fade", "startFrame": 60, "endFrame": 150,
        "layers": [
          { "id": "bg", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#8b5cf6" }, "opacity": 0, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 0, "duration": 30 }] },
          { "id": "title", "type": "text", "position": { "x": 160, "y": 440 }, "size": { "width": 1600, "height": 120 }, "props": { "text": "Fade Transition", "fontSize": 80, "fontWeight": "bold", "color": "#ffffff", "textAlign": "center" }, "opacity": 0, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 15, "duration": 20 }] },
          { "id": "desc", "type": "text", "position": { "x": 160, "y": 580 }, "size": { "width": 1600, "height": 60 }, "props": { "text": "Crossfade between scenes", "fontSize": 32, "color": "#ddd6fe", "textAlign": "center" }, "opacity": 0, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 20, "duration": 20 }] },
          { "id": "fadeout", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#8b5cf6" }, "animations": [{ "type": "exit", "effect": "fadeOut", "delay": 75, "duration": 15 }] }
        ]
      },
      {
        "id": "slide-left", "startFrame": 150, "endFrame": 240,
        "layers": [
          { "id": "bg", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#ec4899" }, "animations": [{ "type": "entrance", "effect": "slideInRight", "delay": 0, "duration": 30 }] },
          { "id": "title", "type": "text", "position": { "x": 160, "y": 440 }, "size": { "width": 1600, "height": 120 }, "props": { "text": "Slide Left", "fontSize": 80, "fontWeight": "bold", "color": "#ffffff", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "slideInRight", "delay": 0, "duration": 30 }] },
          { "id": "desc", "type": "text", "position": { "x": 160, "y": 580 }, "size": { "width": 1600, "height": 60 }, "props": { "text": "Slides in from right", "fontSize": 32, "color": "#fbcfe8", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "slideInRight", "delay": 5, "duration": 30 }] },
          { "id": "exit-left", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#ec4899" }, "animations": [{ "type": "exit", "effect": "slideOutLeft", "delay": 75, "duration": 15 }] },
          { "id": "exit-title", "type": "text", "position": { "x": 160, "y": 440 }, "size": { "width": 1600, "height": 120 }, "props": { "text": "Slide Left", "fontSize": 80, "fontWeight": "bold", "color": "#ffffff", "textAlign": "center" }, "animations": [{ "type": "exit", "effect": "slideOutLeft", "delay": 75, "duration": 15 }] }
        ]
      },
      {
        "id": "slide-up", "startFrame": 240, "endFrame": 330,
        "layers": [
          { "id": "bg", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#f97316" }, "animations": [{ "type": "entrance", "effect": "slideInUp", "delay": 0, "duration": 30 }] },
          { "id": "title", "type": "text", "position": { "x": 160, "y": 440 }, "size": { "width": 1600, "height": 120 }, "props": { "text": "Slide Up", "fontSize": 80, "fontWeight": "bold", "color": "#ffffff", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "slideInUp", "delay": 0, "duration": 30 }] },
          { "id": "desc", "type": "text", "position": { "x": 160, "y": 580 }, "size": { "width": 1600, "height": 60 }, "props": { "text": "Slides in from bottom", "fontSize": 32, "color": "#fed7aa", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "slideInUp", "delay": 5, "duration": 30 }] },
          { "id": "exit-zoom", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#f97316" }, "animations": [{ "type": "exit", "effect": "zoomOut", "delay": 75, "duration": 15 }] },
          { "id": "exit-title", "type": "text", "position": { "x": 160, "y": 440 }, "size": { "width": 1600, "height": 120 }, "props": { "text": "Slide Up", "fontSize": 80, "fontWeight": "bold", "color": "#ffffff", "textAlign": "center" }, "animations": [{ "type": "exit", "effect": "zoomOut", "delay": 75, "duration": 15 }] }
        ]
      },
      {
        "id": "zoom", "startFrame": 330, "endFrame": 420,
        "layers": [
          { "id": "bg", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#22c55e" }, "animations": [{ "type": "entrance", "effect": "zoomIn", "delay": 0, "duration": 30 }] },
          { "id": "title", "type": "text", "position": { "x": 160, "y": 440 }, "size": { "width": 1600, "height": 120 }, "props": { "text": "Zoom Transition", "fontSize": 80, "fontWeight": "bold", "color": "#ffffff", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "zoomIn", "delay": 0, "duration": 30 }] },
          { "id": "desc", "type": "text", "position": { "x": 160, "y": 580 }, "size": { "width": 1600, "height": 60 }, "props": { "text": "Scale in/out effect", "fontSize": 32, "color": "#bbf7d0", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "zoomIn", "delay": 5, "duration": 30 }] },
          { "id": "fadeout", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#000000" }, "opacity": 0, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 75, "duration": 15 }] }
        ]
      },
      {
        "id": "end", "startFrame": 420, "endFrame": 450,
        "layers": [
          { "id": "bg", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#0f172a" } },
          { "id": "title", "type": "text", "position": { "x": 160, "y": 480 }, "size": { "width": 1600, "height": 120 }, "props": { "text": "The End", "fontSize": 80, "fontWeight": "bold", "color": "#ffffff", "textAlign": "center" }, "opacity": 0, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 0, "duration": 20 }] }
        ]
      }
    ]
  }
}
