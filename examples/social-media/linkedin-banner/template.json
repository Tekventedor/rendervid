{
  "name": "LinkedIn Banner",
  "description": "Professional banner image for LinkedIn company pages and profiles.",
  "version": "1.0.0",
  "output": {
    "type": "image",
    "width": 1584,
    "height": 396
  },
  "inputs": [
    {
      "key": "companyName",
      "type": "string",
      "label": "Company Name",
      "description": "Your company or personal brand name",
      "required": true,
      "default": "Your Company"
    },
    {
      "key": "tagline",
      "type": "string",
      "label": "Tagline",
      "description": "Company tagline or description",
      "required": false,
      "default": "Building the future of technology"
    },
    {
      "key": "ctaText",
      "type": "string",
      "label": "CTA Text",
      "description": "Call to action text",
      "required": false,
      "default": "We're Hiring!"
    },
    {
      "key": "primaryColor",
      "type": "color",
      "label": "Primary Color",
      "required": false,
      "default": "#0a66c2"
    },
    {
      "key": "backgroundColor",
      "type": "color",
      "label": "Background Color",
      "required": false,
      "default": "#1b1f23"
    }
  ],
  "defaults": {
    "companyName": "Your Company",
    "tagline": "Building the future of technology",
    "ctaText": "We're Hiring!",
    "primaryColor": "#0a66c2",
    "backgroundColor": "#1b1f23"
  },
  "composition": {
    "scenes": [
      {
        "id": "main",
        "startFrame": 0,
        "endFrame": 1,
        "layers": [
          {
            "id": "background",
            "type": "shape",
            "position": { "x": 0, "y": 0 },
            "size": { "width": 1584, "height": 396 },
            "props": {
              "shape": "rectangle",
              "gradient": {
                "type": "linear",
                "colors": [
                  { "offset": 0, "color": "{{backgroundColor}}" },
                  { "offset": 1, "color": "#2d333b" }
                ],
                "angle": 90
              }
            }
          },
          {
            "id": "accent-bar",
            "type": "shape",
            "position": { "x": 0, "y": 390 },
            "size": { "width": 1584, "height": 6 },
            "props": {
              "shape": "rectangle",
              "gradient": {
                "type": "linear",
                "colors": [
                  { "offset": 0, "color": "{{primaryColor}}" },
                  { "offset": 1, "color": "#0077b5" }
                ],
                "angle": 90
              }
            }
          },
          {
            "id": "pattern",
            "type": "shape",
            "position": { "x": 1200, "y": -100 },
            "size": { "width": 500, "height": 500 },
            "opacity": 0.08,
            "props": {
              "shape": "ellipse",
              "fill": "{{primaryColor}}"
            }
          },
          {
            "id": "company-name",
            "type": "text",
            "position": { "x": 80, "y": 100 },
            "size": { "width": 800, "height": 80 },
            "props": {
              "text": "{{companyName}}",
              "fontSize": 52,
              "fontWeight": "bold",
              "color": "#ffffff",
              "textAlign": "left",
              "fontFamily": "Inter, system-ui, sans-serif"
            }
          },
          {
            "id": "tagline",
            "type": "text",
            "position": { "x": 80, "y": 190 },
            "size": { "width": 700, "height": 50 },
            "props": {
              "text": "{{tagline}}",
              "fontSize": 24,
              "fontWeight": "normal",
              "color": "#8b949e",
              "textAlign": "left",
              "fontFamily": "Inter, system-ui, sans-serif"
            }
          },
          {
            "id": "cta-bg",
            "type": "shape",
            "position": { "x": 80, "y": 270 },
            "size": { "width": 180, "height": 44 },
            "props": {
              "shape": "rectangle",
              "fill": "{{primaryColor}}",
              "borderRadius": 22
            }
          },
          {
            "id": "cta-text",
            "type": "text",
            "position": { "x": 80, "y": 280 },
            "size": { "width": 180, "height": 30 },
            "props": {
              "text": "{{ctaText}}",
              "fontSize": 16,
              "fontWeight": "bold",
              "color": "#ffffff",
              "textAlign": "center",
              "fontFamily": "Inter, system-ui, sans-serif"
            }
          }
        ]
      }
    ]
  }
}
