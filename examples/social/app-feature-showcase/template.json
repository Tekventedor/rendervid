    {
      "key": "feature2",
      "type": "string",
      "label": "Feature 2",
      "required": false,
      "default": "Smart Notifications"
    },
    {
      "key": "feature3",
      "type": "string",
      "label": "Feature 3",
      "required": false,
      "default": "Cloud Sync Everywhere"
    },
    {
      "key": "screenshotUrl",
      "type": "url",
      "label": "App Screenshot",
      "description": "Screenshot of the app to display inside the phone mockup",
      "required": false,
      "default": "https://images.unsplash.com/photo-1611162617474-5b21e879e113?w=400&h=800&fit=crop",
      "validation": {
        "allowedTypes": ["image"]
