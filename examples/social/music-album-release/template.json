              "text": "{{artistName}}",
              "fontSize": 42,
              "fontWeight": "300",
              "color": "#ffffff",
              "textAlign": "center",
              "fontFamily": "Inter, system-ui, sans-serif",
              "letterSpacing": 8
            },
            "animations": [
              {
                "type": "entrance",
                "effect": "fadeInUp",
                "delay": 50,
                "duration": 25,
                "easing": "easeOutCubic"
              }
            ]
          },
          {
            "id": "album-title",
            "type": "text",
            "position": { "x": 90, "y": 810 },
            "size": { "width": 900, "height": 70 },
            "props": {
              "text": "{{albumTitle}}",
              "fontSize": 56,
              "fontWeight": "800",
              "color": "#ffffff",
              "textAlign": "center",
              "fontFamily": "Inter, system-ui, sans-serif",
              "letterSpacing": -1,
              "textShadow": "0 2px 20px rgba(244,63,94,0.4)"
