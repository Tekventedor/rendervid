                "type": "entrance",
                "effect": "bounceIn",
                "delay": 80,
                "duration": 30,
                "easing": "easeOutBounce"
              }
            ]
          },
          {
            "id": "out-now-text",
            "type": "text",
            "position": { "x": 410, "y": 910 },
            "size": { "width": 260, "height": 35 },
            "from": 85,
            "props": {
              "text": "OUT NOW",
              "fontSize": 20,
              "fontWeight": "800",
              "color": "#ffffff",
              "textAlign": "center",
              "fontFamily": "Inter, system-ui, sans-serif",
