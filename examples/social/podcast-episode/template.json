{
  "name": "Podcast Episode Promo",
  "description": "Square format podcast episode promotion with cover art, animated sound wave bars, episode details, guest info, and streaming platform badges.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1080,
    "height": 1080,
    "fps": 30,
    "duration": 6
  },
  "inputs": [
    {
      "key": "showName",
      "type": "string",
      "label": "Show Name",
      "required": true,
      "default": "THE CREATIVE HOUR"
    },
    {
      "key": "episodeNumber",
      "type": "string",
      "label": "Episode Number",
      "required": false,
      "default": "47"
    },
    {
      "key": "episodeTitle",
      "type": "string",
      "label": "Episode Title",
      "required": true,
      "default": "Design Systems That Scale"
    },
    {
      "key": "guestName",
      "type": "string",
      "label": "Guest Name",
      "required": false,
      "default": "Marcus Chen"
    },
    {
      "key": "coverArt",
      "type": "url",
      "label": "Podcast Cover Art",
      "description": "Square podcast cover art image",
      "required": false,
      "default": "https://images.unsplash.com/photo-1478737270239-2f02b77fc618?w=400&h=400&fit=crop",
      "validation": {
        "allowedTypes": ["image"]
      }
    },
    {
      "key": "accentColor",
      "type": "color",
      "label": "Accent Color",
      "required": false,
      "default": "#10b981"
    }
  ],
  "defaults": {
    "showName": "THE CREATIVE HOUR",
    "episodeNumber": "47",
    "episodeTitle": "Design Systems That Scale",
    "guestName": "Marcus Chen",
    "coverArt": "https://images.unsplash.com/photo-1478737270239-2f02b77fc618?w=400&h=400&fit=crop",
    "accentColor": "#10b981"
  },
