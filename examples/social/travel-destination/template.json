{
  "name": "Travel Destination Card",
  "description": "Full HD travel destination showcase with large background image, dark overlay gradient, location details, star ratings, pricing, and a Book Now CTA.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 7
  },
  "inputs": [
    {
      "key": "destination",
      "type": "string",
      "label": "Destination Name",
      "required": true,
      "default": "Santorini"
    },
    {
      "key": "country",
      "type": "string",
      "label": "Country / Region",
      "required": false,
      "default": "Greece, Mediterranean"
    },
    {
      "key": "price",
      "type": "string",
      "label": "Price",
      "required": false,
      "default": "From $299/night"
    },
    {
      "key": "rating",
      "type": "string",
      "label": "Rating (e.g. 4.8)",
      "required": false,
      "default": "4.8"
    },
    {
      "key": "backgroundImage",
      "type": "url",
      "label": "Destination Photo",
      "description": "Background image URL for the destination",
      "required": false,
      "default": "https://images.unsplash.com/photo-1570077188670-e3a8d69ac5ff?w=1920&h=1080&fit=crop",
      "validation": {
        "allowedTypes": ["image"]
      }
    }
  ],
  "defaults": {
    "destination": "Santorini",
    "country": "Greece, Mediterranean",
    "price": "From $299/night",
    "rating": "4.8",
    "backgroundImage": "https://images.unsplash.com/photo-1570077188670-e3a8d69ac5ff?w=1920&h=1080&fit=crop"
  },
