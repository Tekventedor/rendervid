{
  "name": "End Screen",
  "description": "Professional end screen with subscribe and follow CTAs.",
  "version": "1.0.0",
  "output": { "type": "video", "width": 1920, "height": 1080, "fps": 30, "duration": 8 },
  "inputs": [
    { "key": "thanksText", "type": "string", "label": "Thanks Text", "required": true, "default": "Thanks for Watching!" },
    { "key": "channelName", "type": "string", "label": "Channel Name", "required": true, "default": "GameMaster Pro" },
    { "key": "nextStream", "type": "string", "label": "Next Stream", "required": false, "default": "Next Stream: Saturday 8PM EST" }
  ],
  "defaults": { "thanksText": "Thanks for Watching!", "channelName": "GameMaster Pro", "nextStream": "Next Stream: Saturday 8PM EST" },
  "composition": { "scenes": [{ "id": "main", "startFrame": 0, "endFrame": 240, "layers": [
    { "id": "bg", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 1080 }, "props": { "shape": "rectangle", "fill": "#18181b" } },
    { "id": "accent", "type": "shape", "position": { "x": 0, "y": 0 }, "size": { "width": 1920, "height": 10 }, "props": { "shape": "rectangle", "fill": "#ef4444" }, "animations": [{ "type": "entrance", "effect": "slideInLeft", "delay": 0, "duration": 20 }] },
    { "id": "thanks", "type": "text", "position": { "x": 260, "y": 220 }, "size": { "width": 1400, "height": 100 }, "props": { "text": "{{thanksText}}", "fontSize": 72, "fontWeight": "bold", "color": "#ffffff", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "scaleIn", "delay": 20, "duration": 30 }] },
    { "id": "sub-bg", "type": "shape", "position": { "x": 560, "y": 400 }, "size": { "width": 350, "height": 100 }, "props": { "shape": "rectangle", "fill": "#ef4444" }, "animations": [{ "type": "entrance", "effect": "scaleIn", "delay": 40, "duration": 25 }] },
    { "id": "sub-text", "type": "text", "position": { "x": 560, "y": 430 }, "size": { "width": 350, "height": 50 }, "props": { "text": "SUBSCRIBE", "fontSize": 32, "fontWeight": "bold", "color": "#ffffff", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 55, "duration": 20 }] },
    { "id": "follow-bg", "type": "shape", "position": { "x": 1010, "y": 400 }, "size": { "width": 350, "height": 100 }, "props": { "shape": "rectangle", "fill": "#7c3aed" }, "animations": [{ "type": "entrance", "effect": "scaleIn", "delay": 45, "duration": 25 }] },
    { "id": "follow-text", "type": "text", "position": { "x": 1010, "y": 430 }, "size": { "width": 350, "height": 50 }, "props": { "text": "FOLLOW", "fontSize": 32, "fontWeight": "bold", "color": "#ffffff", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 60, "duration": 20 }] },
    { "id": "channel", "type": "text", "position": { "x": 560, "y": 620 }, "size": { "width": 800, "height": 60 }, "props": { "text": "{{channelName}}", "fontSize": 48, "fontWeight": "600", "color": "#ffffff", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "slideInUp", "delay": 65, "duration": 25 }] },
    { "id": "next", "type": "text", "position": { "x": 560, "y": 900 }, "size": { "width": 800, "height": 50 }, "props": { "text": "{{nextStream}}", "fontSize": 24, "color": "#6b7280", "textAlign": "center" }, "animations": [{ "type": "entrance", "effect": "fadeIn", "delay": 80, "duration": 20 }] }
  ]}]}
}
