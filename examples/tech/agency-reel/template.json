{
  "name": "Agency Portfolio Reel",
  "description": "A dynamic 3-scene agency portfolio reel with bold typography, geometric accents, and staggered animations. Scene 1: Agency intro, Scene 2: Services showcase, Scene 3: Contact CTA. Perfect for digital agencies, design studios, and creative portfolios.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 9
  },
  "inputs": [
    {
      "key": "agencyName",
      "type": "string",
      "label": "Agency Name",
      "description": "Your agency or studio name",
      "required": true,
      "default": "PIXEL FORGE"
    },
    {
      "key": "tagline",
      "type": "string",
      "label": "Tagline",
      "description": "Agency tagline",
      "required": false,
      "default": "We Create Digital Experiences"
    },
    {
      "key": "email",
      "type": "string",
      "label": "Email",
      "description": "Contact email address",
      "required": false,
      "default": "hello@pixelforge.studio"
    },
    {
      "key": "website",
      "type": "string",
      "label": "Website",
      "description": "Agency website",
      "required": false,
      "default": "pixelforge.studio"
    },
    {
      "key": "accentColor",
      "type": "color",
      "label": "Accent Color",
      "description": "Primary accent color",
      "required": false,
      "default": "#3b82f6"
    }
  ],
  "defaults": {
    "agencyName": "PIXEL FORGE",
    "tagline": "We Create Digital Experiences",
    "email": "hello@pixelforge.studio",
    "website": "pixelforge.studio",
    "accentColor": "#3b82f6"
  },
