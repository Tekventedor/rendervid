{
  "name": "Tech Startup Hero",
  "description": "A bold, modern SaaS-style hero video with gradient backgrounds, decorative shapes, badge pill, headline, feature bullets, and a call-to-action button. Perfect for product launches, landing pages, and startup pitch videos.",
  "version": "1.0.0",
  "output": {
    "type": "video",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "duration": 8
  },
  "inputs": [
    {
      "key": "badgeText",
      "type": "string",
      "label": "Badge Text",
      "description": "Small pill badge text at top",
      "required": false,
      "default": "LAUNCHING SOON"
    },
    {
      "key": "headline",
      "type": "string",
      "label": "Headline",
      "description": "Primary hero headline",
      "required": true,
      "default": "Ship faster with\nAI-powered workflows"
    },
    {
      "key": "feature1",
      "type": "string",
      "label": "Feature 1",
      "description": "First feature bullet point",
      "required": false,
      "default": "Automated CI/CD pipelines in minutes"
    },
    {
      "key": "feature2",
      "type": "string",
      "label": "Feature 2",
      "description": "Second feature bullet point",
      "required": false,
      "default": "Real-time collaboration across teams"
    },
    {
      "key": "feature3",
      "type": "string",
      "label": "Feature 3",
      "description": "Third feature bullet point",
      "required": false,
      "default": "Enterprise-grade security built in"
    },
    {
      "key": "ctaText",
      "type": "string",
      "label": "CTA Button Text",
      "description": "Call-to-action button label",
      "required": false,
      "default": "Get Early Access"
    },
    {
      "key": "primaryColor",
      "type": "color",
      "label": "Primary Color",
      "description": "Primary accent color for buttons and highlights",
      "required": false,
      "default": "#6366f1"
    },
    {
      "key": "secondaryColor",
      "type": "color",
      "label": "Secondary Color",
      "description": "Secondary gradient color",
      "required": false,
      "default": "#8b5cf6"
    }
  ],
  "defaults": {
    "badgeText": "LAUNCHING SOON",
    "headline": "Ship faster with\nAI-powered workflows",
    "feature1": "Automated CI/CD pipelines in minutes",
