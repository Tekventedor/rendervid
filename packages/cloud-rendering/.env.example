# ========================================
# AWS Configuration
# ========================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# AWS Lambda Function Names (from deployment)
AWS_MAIN_FUNCTION_NAME=rendervid-main
AWS_WORKER_FUNCTION_NAME=rendervid-worker
AWS_MERGER_FUNCTION_NAME=rendervid-merger

# AWS S3 Bucket
AWS_S3_BUCKET=rendervid-renders
AWS_S3_PREFIX=rendervid  # Path prefix in bucket (default: rendervid)

# AWS Lambda Layer ARN
AWS_CHROMIUM_LAYER_ARN=arn:aws:lambda:us-east-1:...:layer:chromium:1

# ========================================
# Azure Configuration
# ========================================
AZURE_SUBSCRIPTION_ID=...
AZURE_TENANT_ID=...
AZURE_CLIENT_ID=...
AZURE_CLIENT_SECRET=...

# Azure Function App Names (from deployment)
AZURE_FUNCTION_APP_NAME=rendervid-functions
AZURE_MAIN_FUNCTION_NAME=MainCoordinator
AZURE_WORKER_FUNCTION_NAME=WorkerRenderer
AZURE_MERGER_FUNCTION_NAME=MergerConcat

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT=rendervidstorageaz
AZURE_STORAGE_CONTAINER=renders
AZURE_STORAGE_PREFIX=rendervid  # Path prefix in container (default: rendervid)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...

# ========================================
# Google Cloud Configuration
# ========================================
GCP_PROJECT_ID=my-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# GCP Cloud Function Names (from deployment)
GCP_MAIN_FUNCTION_NAME=rendervid-main
GCP_WORKER_FUNCTION_NAME=rendervid-worker
GCP_MERGER_FUNCTION_NAME=rendervid-merger

# GCP Cloud Storage Bucket
GCP_STORAGE_BUCKET=rendervid-renders-gcp
GCP_STORAGE_PREFIX=rendervid  # Path prefix in bucket (default: rendervid)

# ========================================
# General Settings
# ========================================
DEFAULT_PROVIDER=aws  # 'aws' | 'azure' | 'gcp'
