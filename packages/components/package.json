{
  "name": "@rendervid/components",
  "version": "0.1.0",
  "description": "Built-in React components for Rendervid templates",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rendervid/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "lottie-web": {
      "optional": true
    },
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@types/react": "18.3.0",
    "@types/react-dom": "18.3.0",
    "jsdom": "^23.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "keywords": [
    "rendervid",
    "components",
    "react",
    "video",
    "animation"
  ],
  "license": "MIT"
}
