{
  "name": "@rendervid/editor",
  "version": "0.1.0",
  "description": "Visual editor component for Rendervid templates",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && npm run build:css",
    "build:css": "tailwindcss -i src/styles/index.css -o dist/styles.css --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.14",
    "@rendervid/components": "workspace:*",
    "@rendervid/core": "workspace:*",
    "@rendervid/renderer-browser": "workspace:*",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@types/react": "18.3.0",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "^10.4.24",
    "jsdom": "^23.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "keywords": [
    "rendervid",
    "video",
    "editor",
    "template",
    "react"
  ],
  "license": "MIT"
}
