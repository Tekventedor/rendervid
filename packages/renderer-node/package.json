{
  "name": "@rendervid/renderer-node",
  "version": "0.1.0",
  "description": "Node.js video renderer using headless browser and FFmpeg",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@rendervid/components": "workspace:*",
    "@rendervid/core": "workspace:*",
    "@rendervid/renderer-browser": "workspace:*",
    "fluent-ffmpeg": "^2.1.3",
    "playwright": "^1.58.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "^0.33.5",
    "three": "^0.163.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "keywords": [
    "rendervid",
    "video",
    "render",
    "node",
    "puppeteer",
    "ffmpeg"
  ],
  "license": "MIT"
}
