{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "paths": {
      "@rendervid/core": ["./packages/core/src"],
      "@rendervid/renderer-browser": ["./packages/renderer-browser/src"],
      "@rendervid/renderer-node": ["./packages/renderer-node/src"],
      "@rendervid/player": ["./packages/player/src"],
      "@rendervid/components": ["./packages/components/src"]
    }
  },
  "include": ["packages/*/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
